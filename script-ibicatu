local carroAtual = nil
local seatAtual = nil
local cacheSusp = nil

local function atualizarContexto()
	local c, s = contextoVeiculo()
	if c ~= carroAtual then
		carroAtual = c
		seatAtual = s
		cacheSusp = nil
	end
end

local function pegarSuspensoesCache()
	if not carroAtual then return nil end
	if cacheSusp then return cacheSusp end
	cacheSusp = coletarSuspensoes(carroAtual)
	return cacheSusp
end

local function alturaParaY(altura)
	local t = (clamp(altura, alturaMin, alturaMax) - alturaMin) / (alturaMax - alturaMin)
	return 1 - clamp(t, 0, 1)
end

local function yParaAltura(yScale)
	local t = 1 - clamp(yScale, 0, 1)
	return alturaMin + t * (alturaMax - alturaMin)
end

local yDesejado = alturaParaY(clamp(alturaPadrao, alturaMin, alturaMax))
local yAtual = yDesejado
local alturaArAtual = clamp(alturaPadrao, alturaMin, alturaMax)

local function setBolaY(yScale)
	bola.Position = UDim2.new(0.5, 0, yScale, 0)
end

setBolaY(yAtual)
sliderValorLabel.Text = "ar: " .. string.format("%.2f", yParaAltura(yAtual))

local function desabilitarInteracao(disabled)
	applyBtn.Active = not disabled
	onlyCamberBtn.Active = not disabled
	applyPlateBtn.Active = not disabled
	bola.Active = not disabled
	applyBtn.AutoButtonColor = not disabled
	onlyCamberBtn.AutoButtonColor = not disabled
	applyPlateBtn.AutoButtonColor = not disabled
	bola.AutoButtonColor = not disabled
	applyBtn.TextTransparency = disabled and 0.35 or 0
	onlyCamberBtn.TextTransparency = disabled and 0.35 or 0
	applyPlateBtn.TextTransparency = disabled and 0.35 or 0
	linha.BackgroundTransparency = disabled and 0.5 or 0
	bola.BackgroundTransparency = disabled and 0.35 or 0
	sliderValorLabel.TextTransparency = disabled and 0.35 or 0
	heightBox.TextTransparency = disabled and 0.35 or 0
	camberBox.TextTransparency = disabled and 0.35 or 0
	plateBox.TextTransparency = disabled and 0.35 or 0
	for _, b in ipairs(corBtns) do
		b.Active = not disabled
		b.AutoButtonColor = not disabled
		b.TextTransparency = disabled and 0.35 or 0
		b.BackgroundTransparency = disabled and 0.35 or 0
	end
end

local function atualizarStatus()
	if not root.Visible then return end
	atualizarContexto()
	local ok = carroAtual ~= nil
	desabilitarInteracao(not ok)
	if not ok then
		setStatus("entre no veículo para mexer")
		return
	end
	setStatus("carro detectado: " .. carroAtual.Name)
end

local function validarValoresManual()
	if not carroAtual then return nil, nil, "entre no veículo para mexer" end
	local h = numero(heightBox.Text)
	local c = numero(camberBox.Text)
	if not h then return nil, nil, "altura inválida" end
	if c == nil then return nil, nil, "camber inválido" end
	return clamp(h, alturaMin, alturaMax), c, nil
end

applyBtn.MouseButton1Click:Connect(function()
	atualizarStatus()
	if not carroAtual then return end
	animBotao(applyBtn)

	local h, c, err = validarValoresManual()
	if err then setStatus(err) return end

	cacheSusp = nil

	yDesejado = alturaParaY(h)
	yAtual = yDesejado
	alturaArAtual = h
	setBolaY(yAtual)
	sliderValorLabel.Text = "ar: " .. string.format("%.2f", yParaAltura(yAtual))

	local hCount, hMsg = aplicarAlturaManual(carroAtual, h)
	local cCount, cMsg = aplicarCamber(carroAtual, c)

	if hCount > 0 or cCount > 0 then
		setStatus("feito: " .. hMsg .. " e " .. cMsg)
	else
		setStatus("não deu: " .. hMsg .. " e " .. cMsg)
	end

	cacheSusp = nil
end)

