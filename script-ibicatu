local function createSlider(parent, config)
    local holder = Instance.new("Frame")
    holder.Parent = parent
    holder.Size = UDim2.new(1, 0, 0, 62)
    holder.BackgroundTransparency = 1

    local label = Instance.new("TextLabel")
    label.Parent = holder
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, 0, 0, 18)
    label.Font = Enum.Font.GothamMedium
    label.TextSize = 12
    label.TextColor3 = Color3.fromRGB(180, 180, 185)
    label.Text = config.Title

    local valueLabel = Instance.new("TextLabel")
    valueLabel.Parent = holder
    valueLabel.BackgroundTransparency = 1
    valueLabel.Size = UDim2.new(1, 0, 0, 18)
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 12
    valueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right

    local sliderFrame = Instance.new("Frame")
    sliderFrame.Parent = holder
    sliderFrame.Position = UDim2.new(0, 0, 0, 26)
    sliderFrame.Size = UDim2.new(1, 0, 0, 32)
    sliderFrame.BackgroundTransparency = 1

    local bar = Instance.new("Frame")
    bar.Parent = sliderFrame
    bar.Position = UDim2.new(0, 0, 0.5, -3)
    bar.Size = UDim2.new(1, 0, 0, 6)
    bar.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    bar.BorderSizePixel = 0

    local barCorner = Instance.new("UICorner")
    barCorner.CornerRadius = UDim.new(1, 0)
    barCorner.Parent = bar

    local fill = Instance.new("Frame")
    fill.Parent = bar
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    fill.BorderSizePixel = 0

    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(1, 0)
    fillCorner.Parent = fill

    local knob = Instance.new("Frame")
    knob.Parent = sliderFrame
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new(0, 0, 0.5, 0)
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0

    local knobCorner = Instance.new("UICorner")
    knobCorner.CornerRadius = UDim.new(1, 0)
    knobCorner.Parent = knob

    local dragging = false
    local currentValue = config.Default or 0

    local function update(input)
        local pos = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
        currentValue = config.Min + (config.Max - config.Min) * pos
        if config.Step then
            currentValue = math.floor(currentValue / config.Step + 0.5) * config.Step
        end
        
        local displayPos = (currentValue - config.Min) / (config.Max - config.Min)
        fill.Size = UDim2.new(displayPos, 0, 1, 0)
        knob.Position = UDim2.new(displayPos, 0, 0.5, 0)
        valueLabel.Text = string.format(config.Format or "%.2f", currentValue)
        
        if config.Changed then
            config.Changed(currentValue)
        end
    end

    sliderFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            update(input)
        end
    end)

    local function setValue(v)
        currentValue = math.clamp(v, config.Min, config.Max)
        local displayPos = (currentValue - config.Min) / (config.Max - config.Min)
        fill.Size = UDim2.new(displayPos, 0, 1, 0)
        knob.Position = UDim2.new(displayPos, 0, 0.5, 0)
        valueLabel.Text = string.format(config.Format or "%.2f", currentValue)
        if config.Changed then
            config.Changed(currentValue)
        end
    end

    setValue(currentValue)

    return {
        SetValue = setValue
    }
end

