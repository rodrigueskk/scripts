local function mostrar()
	if root.Visible then return end
	root.Visible = true
	root.BackgroundTransparency = 1
	border.Transparency = 1
	root.Size = UDim2.new(0, 610, 0, 390)
	TweenService:Create(root, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundTransparency = 0}):Play()
	TweenService:Create(border, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Transparency = 0}):Play()
	TweenService:Create(root, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = UDim2.new(0, 640, 0, 420)}):Play()
end

local function esconder()
	if not root.Visible then return end
	TweenService:Create(root, TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {BackgroundTransparency = 1}):Play()
	TweenService:Create(border, TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {Transparency = 1}):Play()
	local t = TweenService:Create(root, TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {Size = UDim2.new(0, 610, 0, 390)})
	t:Play()
	t.Completed:Connect(function()
		root.Visible = false
	end)
end

local function toggle()
	if root.Visible then esconder() else mostrar() end
end

