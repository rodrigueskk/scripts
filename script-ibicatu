local function screenYParaYScale(screenY)
	local absPos = sliderArea.AbsolutePosition.Y
	local absSize = sliderArea.AbsoluteSize.Y
	local y = (screenY - absPos) / absSize
	return clamp(y, 0, 1)
end

local arrastando = false
local usandoTouch = false
local touchRef = nil

local function iniciarArrastoMouse()
	arrastando = true
	usandoTouch = false
end

local function iniciarArrastoTouch(input)
	arrastando = true
	usandoTouch = true
	touchRef = input
end

local function pararArrasto()
	arrastando = false
	usandoTouch = false
	touchRef = nil
end

local function puxarAgoraPara(screenY)
	yDesejado = screenYParaYScale(screenY)
	yAtual = yDesejado
	setBolaY(yAtual)
	sliderValorLabel.Text = "ar: " .. string.format("%.2f", yParaAltura(yAtual))
end

bola.InputBegan:Connect(function(input)
	atualizarStatus()
	if not carroAtual then return end
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		iniciarArrastoMouse()
		puxarAgoraPara(UserInputService:GetMouseLocation().Y)
	elseif input.UserInputType == Enum.UserInputType.Touch then
		iniciarArrastoTouch(input)
		puxarAgoraPara(input.Position.Y)
	end
end)

sliderArea.InputBegan:Connect(function(input)
	atualizarStatus()
	if not carroAtual then return end
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		iniciarArrastoMouse()
		puxarAgoraPara(UserInputService:GetMouseLocation().Y)
	elseif input.UserInputType == Enum.UserInputType.Touch then
		iniciarArrastoTouch(input)
		puxarAgoraPara(input.Position.Y)
	end
end)

UserInputService.InputEnded:Connect(function(input, gp)
	if gp then return end
	if not arrastando then return end
	if not usandoTouch and input.UserInputType == Enum.UserInputType.MouseButton1 then
		pararArrasto()
	elseif usandoTouch and input.UserInputType == Enum.UserInputType.Touch and touchRef and input == touchRef then
		pararArrasto()
	end
end)

