local tokensRoda = {
	FL = {"FL","FRONTLEFT","FRONT_LEFT","LEFTFRONT","LEFT_FRONT"},
	FR = {"FR","FRONTRIGHT","FRONT_RIGHT","RIGHTFRONT","RIGHT_FRONT"},
	RL = {"RL","REARLEFT","REAR_LEFT","LEFTREAR","LEFT_REAR","BACKLEFT","BACK_LEFT"},
	RR = {"RR","REARRIGHT","REAR_RIGHT","RIGHTREAR","RIGHT_REAR","BACKRIGHT","BACK_RIGHT"},
}

local function numero(texto)
	texto = tostring(texto or ""):gsub(",", ".")
	texto = texto:match("^%s*(.-)%s*$")
	return tonumber(texto)
end

local function clamp(n, a, b)
	if n < a then return a end
	if n > b then return b end
	return n
end

local function tagDaRoda(nomeUpper)
	for tag, lista in pairs(tokensRoda) do
		for _, t in ipairs(lista) do
			if nomeUpper:find(t, 1, true) then
				return tag
			end
		end
	end
	return nil
end

local function humanoidAtual()
	local c = player.Character
	if not c then return nil end
	return c:FindFirstChildOfClass("Humanoid")
end

local function seatMotorista()
	local h = humanoidAtual()
	if not h then return nil end
	local s = h.SeatPart
	if s and s:IsA("VehicleSeat") and s.Occupant == h then
		return s
	end
	return nil
end

local function modeloDoCarro(seat)
	local p = seat
	while p and p ~= workspace do
		if p:IsA("Model") then
			return p
		end
		p = p.Parent
	end
	return nil
end

local function contextoVeiculo()
	local s = seatMotorista()
	if not s then return nil, nil end
	local m = modeloDoCarro(s)
	if not m then return nil, nil end
	return m, s
end

local function coletarSuspensoes(carro)
	local lista = {}
	for _, d in ipairs(carro:GetDescendants()) do
		if d:IsA("SpringConstraint") or d:IsA("PrismaticConstraint") then
			table.insert(lista, d)
		end
	end
	return lista
end

local baseCamber = setmetatable({}, {__mode = "k"})

local function aplicarAlturaConstraint(c, altura)
	altura = clamp(altura, alturaMin, alturaMax)
	if c:IsA("SpringConstraint") then
		local ok = pcall(function()
			c.FreeLength = altura
		end)
		return ok
	end
	if c:IsA("PrismaticConstraint") then
		local ok = pcall(function()
			local half = clamp(math.abs(altura), alturaMin, alturaMax)
			c.LimitsEnabled = true
			c.LowerLimit = -half
			c.UpperLimit = half
		end)
		return ok
	end
	return false
end

local function aplicarAlturaManual(carro, altura)
	local constraints = coletarSuspensoes(carro)
	if #constraints == 0 then
		return 0, "não achei springconstraint ou prismaticconstraint nesse carro"
	end

	local porTag = {FL = {}, FR = {}, RL = {}, RR = {}}
	local temTag = 0

	for _, c in ipairs(constraints) do
		local tag = tagDaRoda(string.upper(c.Name))
		if tag then
			temTag += 1
			table.insert(porTag[tag], c)
		end
	end

	local alterados = 0
	altura = clamp(altura, alturaMin, alturaMax)

	if temTag > 0 then
		for _, tag in ipairs({"FL","FR","RL","RR"}) do
			for _, c in ipairs(porTag[tag]) do
				if aplicarAlturaConstraint(c, altura) then
					alterados += 1
				end
			end
		end
	else
		for _, c in ipairs(constraints) do
			if aplicarAlturaConstraint(c, altura) then
				alterados += 1
			end
		end
	end

	if alterados == 0 then
		return 0, "achei constraints mas não consegui aplicar a altura"
	end

	return alterados, "altura aplicada"
end

local function rotacaoCamber(rad)
	if eixoCamber == "X" then
		return CFrame.Angles(rad, 0, 0)
	end
	return CFrame.Angles(0, 0, rad)
end

local function pareceRoda(nomeUpper)
	return nomeUpper:find("WHEEL", 1, true)
		or nomeUpper:find("RODA", 1, true)
		or nomeUpper:find("TIRE", 1, true)
		or nomeUpper:find("PNEU", 1, true)
end

local function scoreAttachment(att, tag)
	if not att or not att:IsA("Attachment") then return -999 end
	local parent = att.Parent
	if not parent then return -999 end
	local pn = string.upper(parent.Name)
	local s = 0
	if parent:IsA("BasePart") then s += 1 end
	if pareceRoda(pn) then s += 12 end
	if tag and pn:find(tag, 1, true) then s += 6 end
	if pn:find("WHEEL", 1, true) then s += 3 end
	if pn:find("TIRE", 1, true) or pn:find("PNEU", 1, true) then s += 3 end
	local full = string.upper(att:GetFullName())
	if full:find("WHEEL", 1, true) or full:find("RODA", 1, true) or full:find("TIRE", 1, true) or full:find("PNEU", 1, true) then
		s += 2
	end
	return s
end

local function escolherAttachmentDaRoda(constraint, tag)
	local a0 = constraint.Attachment0
	local a1 = constraint.Attachment1
	local s0 = scoreAttachment(a0, tag)
	local s1 = scoreAttachment(a1, tag)
	if s0 > s1 then return a0 end
	if s1 > s0 then return a1 end
	return a1 or a0
end

local function baseDoAttachment(att)
	local base = baseCamber[att]
	if base then return base end
	baseCamber[att] = att.CFrame
	return baseCamber[att]
end

local function aplicarCamberNoAttachment(att, graus)
	local ok = pcall(function()
		local base = baseDoAttachment(att)
		att.CFrame = base * rotacaoCamber(math.rad(graus))
	end)
	return ok
end

local function aplicarCamber(carro, camberGraus)
	local constraints = coletarSuspensoes(carro)
	if #constraints == 0 then
		return 0, "não achei constraints pra aplicar camber"
	end

	local porTag = {FL = {}, FR = {}, RL = {}, RR = {}}
	local temTag = 0

	for _, c in ipairs(constraints) do
		local tag = tagDaRoda(string.upper(c.Name))
		if tag then
			temTag += 1
			table.insert(porTag[tag], c)
		end
	end

	local alterados = 0

	local function aplicarEmConstraint(c, tag, valor)
		local graus = valor
		if inverterLadoDireito and (tag == "FR" or tag == "RR") then
			graus = -valor
		end

		local att = escolherAttachmentDaRoda(c, tag)
		if att and aplicarCamberNoAttachment(att, graus) then
			alterados += 1
			return
		end

		if c.Attachment1 and aplicarCamberNoAttachment(c.Attachment1, graus) then
			alterados += 1
			return
		end

		if c.Attachment0 and aplicarCamberNoAttachment(c.Attachment0, graus) then
			alterados += 1
			return
		end
	end

	if temTag > 0 then
		for _, tag in ipairs({"FL","FR","RL","RR"}) do
			for _, c in ipairs(porTag[tag]) do
				aplicarEmConstraint(c, tag, camberGraus)
			end
		end
	else
		for _, c in ipairs(constraints) do
			aplicarEmConstraint(c, "FL", camberGraus)
		end
	end

	if alterados == 0 then
		return 0, "não consegui aplicar camber"
	end

	return alterados, "camber aplicado"
end

local function acharPlacas(carro)
	local body = carro:FindFirstChild("Body") or carro:FindFirstChild("body") or carro:FindFirstChild("BODY")
	local raiz = body or carro
	local placaVeh = raiz:FindFirstChild("PlacaVEH", true)
	if not placaVeh then return {} end
	local plates = placaVeh:FindFirstChild("Plates") or placaVeh:FindFirstChild("plates") or placaVeh:FindFirstChild("PLATES")
	if not plates then return {} end
	local labels = {}
	for _, d in ipairs(plates:GetDescendants()) do
		if d:IsA("TextLabel") and d.Name == "Identifier" then
			table.insert(labels, d)
		end
	end
	return labels
end

local function aplicarPlaca(carro, texto)
	local labels = acharPlacas(carro)
	if #labels == 0 then
		return false, "não achei Identifier dentro da placa"
	end
	for _, lb in ipairs(labels) do
		pcall(function()
			lb.Text = tostring(texto or "")
		end)
	end
	return true, "placa aplicada"
end

local function childCaseInsensitive(parent, wanted)
	if not parent then return nil end
	for _, ch in ipairs(parent:GetChildren()) do
		if string.lower(ch.Name) == string.lower(wanted) then
			return ch
		end
	end
	return nil
end

local function acharLNs(carro)
	local body = carro:FindFirstChild("Body") or carro:FindFirstChild("body") or carro:FindFirstChild("BODY")
	local raiz = body or carro

	local lights = childCaseInsensitive(raiz, "Lights") or raiz:FindFirstChild("Lights", true) or raiz:FindFirstChild("lights", true)
	if not lights then return {} end

	local headlights = childCaseInsensitive(lights, "Headlights") or childCaseInsensitive(lights, "Highlights") or lights:FindFirstChild("Headlights", true) or lights:FindFirstChild("Highlights", true)
	if not headlights then return {} end

	local low = childCaseInsensitive(headlights, "Low") or headlights:FindFirstChild("Low", true)
	if not low then return {} end

	local lnNode = childCaseInsensitive(low, "LN") or low:FindFirstChild("LN", true)
	local parts = {}

	if lnNode then
		for _, d in ipairs(lnNode:GetDescendants()) do
			if d:IsA("BasePart") then
				table.insert(parts, d)
			end
		end
	end

	for _, d in ipairs(low:GetDescendants()) do
		if d:IsA("BasePart") and string.lower(d.Name) == "ln" then
			table.insert(parts, d)
		end
	end

	local uniq = {}
	local out = {}
	for _, p in ipairs(parts) do
		if p and p.Parent and not uniq[p] then
			uniq[p] = true
			table.insert(out, p)
		end
	end

	return out
end

local function aplicarCorLNs(carro, cor)
	local parts = acharLNs(carro)
	if #parts == 0 then
		return false, "não achei LN em Lights > Headlights > Low"
	end
	for _, p in ipairs(parts) do
		pcall(function()
			p.Color = cor
		end)
	end
	return true, "cor aplicada"
end

