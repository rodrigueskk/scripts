RunService.RenderStepped:Connect(function(dt)
	if not root.Visible then return end
	atualizarContexto()
	if not carroAtual then
		pararArrasto()
		return
	end

	if arrastando then
		if usandoTouch and touchRef then
			yDesejado = screenYParaYScale(touchRef.Position.Y)
		else
			yDesejado = screenYParaYScale(UserInputService:GetMouseLocation().Y)
		end
	end

	local a = 1 - math.exp(-clamp(suavidadeArrasto, 1, 100) * dt)
	yAtual = yAtual + (yDesejado - yAtual) * a
	setBolaY(yAtual)
	sliderValorLabel.Text = "ar: " .. string.format("%.2f", yParaAltura(yAtual))
end)

RunService.Heartbeat:Connect(function(dt)
	atualizarStatus()
	if not root.Visible then return end
	atualizarContexto()
	if not carroAtual then return end

	local cons = pegarSuspensoesCache()
	if not cons or #cons == 0 then return end

	local alvo = clamp(yParaAltura(yAtual), alturaMin, alturaMax)
	local a = 1 - math.exp(-clamp(suavidadeAr, 1, 120) * dt)
	alturaArAtual = alturaArAtual + (alvo - alturaArAtual) * a

	for _, c in ipairs(cons) do
		aplicarAlturaConstraint(c, alturaArAtual)
	end
end)

local function hookChar(char)
	local hum = char:WaitForChild("Humanoid", 10)
	if not hum then return end
	hum:GetPropertyChangedSignal("SeatPart"):Connect(function()
		atualizarContexto()
		atualizarStatus()
		if carroAtual then
			cacheSusp = nil
			local h = clamp(numero(heightBox.Text) or alturaPadrao, alturaMin, alturaMax)
			yDesejado = alturaParaY(h)
			yAtual = yDesejado
			alturaArAtual = h
			setBolaY(yAtual)
			sliderValorLabel.Text = "ar: " .. string.format("%.2f", yParaAltura(yAtual))
		end
	end)
	atualizarContexto()
	atualizarStatus()
end

player.CharacterAdded:Connect(hookChar)
if player.Character then hookChar(player.Character) end

