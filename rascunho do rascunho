local function createToggle(parent, text, default, callback)
    local btn = Instance.new("TextButton")
    btn.Parent = parent
    btn.Size = UDim2.new(1, 0, 0, 36)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 14
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Text = text .. ": " .. (default and "ATIVADO" or "DESATIVADO")
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn
    local state = default
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = text .. ": " .. (state and "ATIVADO" or "DESATIVADO")
        callback(state)
    end)
end

-- Lógica de Compartilhamento
local function salvarConfiguracoes(vehicle)
    if not vehicle then return end
    configuracoesSalvas[vehicle] = {
        suspension = currentSuspension,
        speed = velocityMult,
        brake = velocityMult2,
        grip = currentGrip
    }
end

local function resetarCarro(vehicle)
    if not vehicle then return end
    applyLocalSuspension(2.5, vehicle)
    applyTireGrip(vehicle, 1)
end

