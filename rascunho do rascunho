        if minhaBubble then pcall(function() minhaBubble:Destroy() end) end
        local myChar = player.Character
        if not myChar then return end
        local hrp = myChar:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        minhaBubble = Instance.new("BillboardGui")
        minhaBubble.Adornee = hrp; minhaBubble.AlwaysOnTop = false
        minhaBubble.Size = UDim2.new(0,200,0,40); minhaBubble.StudsOffset = Vector3.new(0,3,0)
        minhaBubble.Parent = playerGui
        local bg2 = Instance.new("Frame"); bg2.Parent = minhaBubble
        bg2.Size = UDim2.new(1,0,1,0); bg2.BackgroundColor3 = Color3.fromRGB(240,240,255)
        bg2.BackgroundTransparency = 0.05; bg2.BorderSizePixel = 0
        local bg2C = Instance.new("UICorner"); bg2C.CornerRadius = UDim.new(0,10); bg2C.Parent = bg2
        local lbl2 = Instance.new("TextLabel"); lbl2.Parent = bg2
        lbl2.Size = UDim2.new(1,-8,1,0); lbl2.Position = UDim2.new(0,4,0,0)
        lbl2.BackgroundTransparency = 1; lbl2.Font = Enum.Font.Gotham; lbl2.TextSize = 12
        lbl2.TextColor3 = Color3.fromRGB(20,20,60); lbl2.Text = texto; lbl2.TextWrapped = true
        task.delay(6, function()
            pcall(function() minhaBubble:Destroy() end)
            minhaBubble = nil
        end)
    end

    local function enviarMensagem(texto)
        if texto == "" then return end
        pcall(function()
            local channels = TextChatService:FindFirstChild("TextChannels")
            if channels then
                local ch = channels:FindFirstChild("RBXGeneral") or channels:GetChildren()[1]
                if ch and ch:IsA("TextChannel") then
                    ch:SendAsync(texto)
                end
            end
        end)
        mostrarMinhaBubble(texto)
        msgBox.Text = ""
        confirmFrame.Visible = false
    end

    local pendingText = ""
    local function tentarEnviar()
        local txt = msgBox.Text
        if txt == "" then return end
        if chatConfirmarEnvio then
            pendingText = txt
            cfPreview.Text = '"' .. txt .. '"'
            confirmFrame.Visible = true
        else
            enviarMensagem(txt)
        end
    end

    cfConfirm.MouseButton1Click:Connect(function()
        enviarMensagem(pendingText)
        pendingText = ""
    end)
    sendBtn.MouseButton1Click:Connect(tentarEnviar)
    msgBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then tentarEnviar() end
    end)

    local novasMensagens = 0
    local usuarioScrollado = false

    local function estaNoFundo()
        local maxY = scroll.AbsoluteCanvasSize.Y - scroll.AbsoluteSize.Y
        return scroll.CanvasPosition.Y >= maxY - 10
    end

    local function irParaOFundo()
        task.wait()
        scroll.CanvasPosition = Vector2.new(0, scroll.AbsoluteCanvasSize.Y)
        novasMensagens = 0; newMsgBadge.Visible = false; usuarioScrollado = false
    end

    newMsgBadge.MouseButton1Click:Connect(irParaOFundo)

    scroll:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
        if estaNoFundo() then
            usuarioScrollado = false; novasMensagens = 0; newMsgBadge.Visible = false
        else
            usuarioScrollado = true
        end
    end)

    local function criarLinhaMsg(dados)
        local row = Instance.new("Frame")
        row.Parent = scroll; row.Size = UDim2.new(1,0,0,0)
        row.AutomaticSize = Enum.AutomaticSize.Y
        row.BackgroundColor3 = dados.isAmigo and Color3.fromRGB(18,30,18) or Color3.fromRGB(20,20,25)
        row.BorderSizePixel = 0; row.ZIndex = 4
        local rowC = Instance.new("UICorner"); rowC.CornerRadius = UDim.new(0,8); rowC.Parent = row
        local rowP = Instance.new("UIPadding"); rowP.Parent = row
        rowP.PaddingLeft = UDim.new(0,8); rowP.PaddingRight = UDim.new(0,8)
        rowP.PaddingTop = UDim.new(0,4); rowP.PaddingBottom = UDim.new(0,4)
        local rowL = Instance.new("UIListLayout"); rowL.Parent = row
        rowL.Padding = UDim.new(0,2); rowL.SortOrder = Enum.SortOrder.LayoutOrder

        local nomeRow = Instance.new("Frame"); nomeRow.Parent = row
        nomeRow.Size = UDim2.new(1,0,0,16); nomeRow.BackgroundTransparency = 1; nomeRow.ZIndex = 5
        local nomeList = Instance.new("UIListLayout"); nomeList.Parent = nomeRow
        nomeList.FillDirection = Enum.FillDirection.Horizontal
        nomeList.Padding = UDim.new(0,4); nomeList.VerticalAlignment = Enum.VerticalAlignment.Center

        if dados.isAmigo then
            local ico = Instance.new("TextLabel"); ico.Parent = nomeRow
            ico.BackgroundTransparency = 1; ico.Size = UDim2.new(0,16,1,0)
            ico.Font = Enum.Font.GothamBold; ico.TextSize = 13
            ico.TextColor3 = Color3.fromRGB(80,210,80); ico.Text = "👤"; ico.ZIndex = 6
        end

        local nomeLbl = Instance.new("TextLabel"); nomeLbl.Parent = nomeRow
        nomeLbl.BackgroundTransparency = 1; nomeLbl.Size = UDim2.new(1,0,1,0)
        nomeLbl.Font = Enum.Font.GothamBold; nomeLbl.TextSize = 12
        nomeLbl.TextColor3 = dados.isAmigo and Color3.fromRGB(80,210,80) or Color3.fromRGB(150,150,210)
        nomeLbl.Text = dados.displayName .. " (@" .. dados.nome .. ")"
        nomeLbl.TextXAlignment = Enum.TextXAlignment.Left; nomeLbl.ZIndex = 6

        local msgLbl = Instance.new("TextLabel"); msgLbl.Parent = row
        msgLbl.BackgroundTransparency = 1; msgLbl.Size = UDim2.new(1,0,0,0)
        msgLbl.AutomaticSize = Enum.AutomaticSize.Y
        msgLbl.Font = Enum.Font.Gotham; msgLbl.TextSize = 12
        msgLbl.TextColor3 = Color3.fromRGB(230,230,238)
        msgLbl.Text = dados.mensagem; msgLbl.TextWrapped = true
        msgLbl.TextXAlignment = Enum.TextXAlignment.Left; msgLbl.ZIndex = 6
        return row
    end

    local chatViewStart = math.max(1, #chatMessages - CHAT_PAGE + 1)

    local loadMoreLbl = Instance.new("TextLabel")
    loadMoreLbl.Parent = scroll
    loadMoreLbl.Size = UDim2.new(1,0,0,22)
    loadMoreLbl.BackgroundColor3 = Color3.fromRGB(25,25,32)
    loadMoreLbl.BorderSizePixel = 0
    loadMoreLbl.Font = Enum.Font.Gotham; loadMoreLbl.TextSize = 10
    loadMoreLbl.TextColor3 = Color3.fromRGB(120,120,140)
    loadMoreLbl.Text = chatViewStart > 1 and ("↑ Toque para ver mais (" .. (chatViewStart-1) .. " anteriores)") or "— Inicio do historico —"
    loadMoreLbl.ZIndex = 4; loadMoreLbl.LayoutOrder = -999999
    local lmlC = Instance.new("UICorner"); lmlC.CornerRadius = UDim.new(0,6); lmlC.Parent = loadMoreLbl

    loadMoreLbl.InputBegan:Connect(function(inp)
        if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        if chatViewStart <= 1 then return end
        local novoStart = math.max(1, chatViewStart - CHAT_LOAD_MORE)
        local prevCanvas = scroll.AbsoluteCanvasSize.Y
        for i = chatViewStart-1, novoStart, -1 do
            local row = criarLinhaMsg(chatMessages[i])
            row.LayoutOrder = i
        end
        chatViewStart = novoStart
        loadMoreLbl.Text = chatViewStart > 1 and ("↑ Toque para ver mais (" .. (chatViewStart-1) .. " anteriores)") or "— Inicio do historico —"
        task.wait()
        local delta = scroll.AbsoluteCanvasSize.Y - prevCanvas
        scroll.CanvasPosition = Vector2.new(0, scroll.CanvasPosition.Y + delta)
    end)

    for i = chatViewStart, #chatMessages do
        local row = criarLinhaMsg(chatMessages[i])
        row.LayoutOrder = i
    end
    task.wait(0.1); irParaOFundo()

    chatHubConn = TextChatService.MessageReceived:Connect(function(msg)
        local sender = msg.TextSource
        if not sender then return end
        local sP  = Players:GetPlayerByUserId(sender.UserId)
        local nome = sP and sP.Name        or tostring(sender.UserId)
        local dn   = sP and sP.DisplayName or nome
        local ami  = sP and isAmigo(sP)    or false
        local txt  = msg.Text              or ""
        local dados = {nome=nome, displayName=dn, mensagem=txt, isAmigo=ami}
        table.insert(chatMessages, dados)
        if #chatMessages > 500 then table.remove(chatMessages, 1) end

        if bubbleChatAtivo and sP and sP ~= player then
            criarBubble(sP, txt)
        end

        local row = criarLinhaMsg(dados)
        row.LayoutOrder = #chatMessages

        if usuarioScrollado then
            novasMensagens = novasMensagens + 1
            newMsgBadge.Text = "+ " .. novasMensagens .. (novasMensagens == 1 and " mensagem nova" or " mensagens novas")
            newMsgBadge.Visible = true
        else
            task.wait()
            scroll.CanvasPosition = Vector2.new(0, scroll.AbsoluteCanvasSize.Y)
        end
    end)

    chatHubGui.AncestryChanged:Connect(function()
        if not chatHubGui.Parent then
            for _, c in ipairs(bubbleConns) do pcall(function() c:Disconnect() end) end
        end
    end)
end

