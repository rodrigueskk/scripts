local function encontrarPartesRodas(vehicle)
    if not vehicle then return {} end
    local partes = {}
    local pastaNames = {"Wheels","wheels","Wheel","wheel","WHEELS","WHEEL"}
    local pasta = nil
    for _, n in ipairs(pastaNames) do
        pasta = vehicle:FindFirstChild(n, true)
        if pasta then break end
    end
    if pasta then
        for _, desc in ipairs(pasta:GetDescendants()) do
            if desc:IsA("BasePart") or desc:IsA("MeshPart") then
                table.insert(partes, desc)
            end
        end
        if #partes == 0 then
            for _, child in ipairs(pasta:GetChildren()) do
                if child:IsA("BasePart") or child:IsA("MeshPart") then
                    table.insert(partes, child)
                end
            end
        end
    end
    if #partes == 0 then
        for _, desc in ipairs(vehicle:GetDescendants()) do
            if (desc:IsA("BasePart") or desc:IsA("MeshPart")) then
                local n = desc.Name:upper()
                if tagDaRoda(n) then
                    table.insert(partes, desc)
                end
            end
        end
    end
    return partes
end

local function capturarTamanhosOriginais(vehicle)
    local partes = encontrarPartesRodas(vehicle)
    wheelPartsOrig = {}
    local vehCF = vehicle:GetPivot()
    for _, p in ipairs(partes) do
        wheelPartsOrig[p] = {
            size    = p.Size,
            cframe  = p.CFrame,
            localCF = vehCF:ToObjectSpace(p.CFrame),
        }
    end
    wheelModels = partes
    return #partes > 0
end

local function aplicarEscalaRodas(fator)
    local vehicle = getVehicle()
    local seat = vehicle and getVehicleSeat(vehicle)
    local savedVel    = seat and seat.AssemblyLinearVelocity
    local savedAngVel = seat and seat.AssemblyAngularVelocity

    for part, origData in pairs(wheelPartsOrig) do
        if part and part.Parent then
            pcall(function()
                local origSize = origData.size
                local newSize  = origSize * fator

                if vehicle then
                    local vehCF   = vehicle:GetPivot()
                    local worldCF = vehCF * origData.localCF
                    part.Size   = newSize
                    part.CFrame = worldCF
                else
                    part.Size   = newSize
                    part.CFrame = origData.cframe
                end
            end)
        end
    end

    if seat and savedVel then
        pcall(function()
            seat.AssemblyLinearVelocity  = savedVel
            seat.AssemblyAngularVelocity = savedAngVel
        end)
    end
end

