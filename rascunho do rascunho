local function pararAutoFarm()
    autoFarmAtivo = false
    if autoFarmConn then autoFarmConn:Disconnect(); autoFarmConn = nil end
    autoFarmBtn.Text = "▶ Ativar AutoFarm"
    autoFarmBtn.BackgroundColor3 = Color3.fromRGB(32, 32, 36)
    autoFarmBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
end

local function iniciarAutoFarm()
    local vehicle = getVehicle()
    if not vehicle then
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = "AutoFarm",
                Text = "Entre em um VehicleSeat primeiro",
                Duration = 3
            })
        end)
        return
    end

    -- Remove o limite de velocidade do VehicleSeat
    local seat0 = getVehicleSeat(vehicle)
    if seat0 then
        pcall(function() seat0.MaxSpeed = 9999 end)
    end

    autoFarmAtivo = true
    autoFarmDir   = 1
    autoFarmBtn.Text = "⏹ Parar AutoFarm"
    TweenService:Create(autoFarmBtn, TweenInfo.new(0.15), {
        BackgroundColor3 = Color3.fromRGB(0, 180, 80),
        TextColor3 = Color3.fromRGB(255, 255, 255)
    }):Play()

    autoFarmConn = RunService.Stepped:Connect(function()
        if not autoFarmAtivo then return end
        local v2 = getVehicle()
        local seat = v2 and getVehicleSeat(v2)
        if not seat then pararAutoFarm(); return end

        -- Garante MaxSpeed alto todo frame (alguns jogos resetam)
        pcall(function() seat.MaxSpeed = 9999 end)

        local pos = seat.Position
        if pos.Y < AUTO_ALTURA - 5 then
            -- Sobe rapidamente
            seat.AssemblyLinearVelocity = Vector3.new(0, AUTO_SPEED, 0)
        else
            -- Voa em alta velocidade indo e voltando
            seat.AssemblyLinearVelocity = Vector3.new(AUTO_SPEED * autoFarmDir, 0, 0)
            seat.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            if math.abs(pos.X) > 400 then
                autoFarmDir = -autoFarmDir
            end
        end
    end)
end

