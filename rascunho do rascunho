-- Cor do time via Teams
local function getTeamColor(targetPlayer)
    local Teams = game:GetService("Teams")
    if not Teams then return Color3.fromRGB(150,150,150) end
    for _, team in ipairs(Teams:GetTeams()) do
        if targetPlayer.Team == team then
            return team.TeamColor.Color
        end
    end
    return Color3.fromRGB(150, 150, 150)
end

local function atualizarCorTime()
    for pName, bb in pairs(trackerLabels) do
        local p = Players:FindFirstChild(pName)
        if p and bb and bb.Parent then
            local bg = bb:FindFirstChildOfClass("Frame")
            if bg then
                local stroke = bg:FindFirstChildOfClass("UIStroke")
                local nameLabel = bg:FindFirstChildOfClass("TextLabel")
                local cor = eAlvo(p) and COR_ALVO or getTeamColor(p)
                if stroke then stroke.Color = cor end
                if nameLabel then nameLabel.TextColor3 = cor end
            end
        end
    end
end

-- FPS: acumula frames e atualiza a cada 0.5s
local fpsFrameCount = 0
local fpsTimer      = 0
local fpsESPTimer   = 0

RunService.Stepped:Connect(function(_, dt)
    local vehicle = getVehicle()

    -- Tracker: cores de time
    atualizarCorTime()

    -- FPS counter
    if fpsAtivo then
        fpsFrameCount = fpsFrameCount + 1
        fpsTimer = fpsTimer + dt
        if fpsTimer >= 0.5 then
            local fps = math.floor(fpsFrameCount / fpsTimer)
            fpsLabel.Text = "FPS: " .. fps
            -- Cor baseada no FPS: verde > 50, amarelo > 25, vermelho <= 25
            if fps > 50 then
                fpsLabel.TextColor3 = Color3.fromRGB(0, 220, 100)
            elseif fps > 25 then
                fpsLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
            else
                fpsLabel.TextColor3 = Color3.fromRGB(220, 60, 60)
            end
            fpsFrameCount = 0
            fpsTimer      = 0
        end
    end

    -- ESP de veículos: escaneia a cada 3s (SelectionBox cuida do resto sozinha)
    if espAtivo then
        fpsESPTimer = fpsESPTimer + dt
        if fpsESPTimer >= 3 then
            fpsESPTimer = 0
            escanearVeiculos()
        end
    end

    if not vehicle then return end
    local seat = getVehicleSeat(vehicle)
    if not seat then return end

    -- Velocidade (W)
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
        seat.AssemblyLinearVelocity *= Vector3.new(1 + velocityMult, 1, 1 + velocityMult)
    end
    -- Frenagem (S)
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
        seat.AssemblyLinearVelocity *= Vector3.new(1 - velocityMult2, 1, 1 - velocityMult2)
    end

    -- Compartilhar Dados
    if compartilharDados and outroJogadorNoVeiculo(vehicle) then
        applyLocalSuspension(savedConfig.suspension)
        applyTireGrip(vehicle, savedConfig.grip)
    end

    -- Anti-Flip
    if antiFlipAtivo then
        local upVec = seat.CFrame.UpVector
        if upVec.Y < 0.3 then
            pcall(function()
                seat.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                local pos = seat.Position
                seat.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
                    * CFrame.Angles(0, math.atan2(seat.CFrame.LookVector.X, seat.CFrame.LookVector.Z), 0)
            end)
        end
    end

    -- Anti-Voo: zera velocidade vertical positiva em alta velocidade
    if antivooAtivo then
        local vel  = seat.AssemblyLinearVelocity
        local velH = Vector3.new(vel.X, 0, vel.Z).Magnitude
        -- Ativa acima de ~195 studs/s (≈700 km/h) quando o carro está subindo
        if velH > 195 and vel.Y > 1 then
            pcall(function()
                seat.AssemblyLinearVelocity = Vector3.new(vel.X, 0, vel.Z)
            end)
        end
    end
end)
