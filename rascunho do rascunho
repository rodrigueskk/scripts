    label.Text = text
    label.TextXAlignment = Enum.TextXAlignment.Left

    local bg = Instance.new("Frame")
    bg.Parent = container
    bg.Position = UDim2.new(1, -44, 0.5, -11)
    bg.Size = UDim2.new(0, 40, 0, 22)
    bg.BackgroundColor3 = default and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(45, 45, 50)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = bg

    local dot = Instance.new("Frame")
    dot.Parent = bg
    dot.Position = default and UDim2.new(1, -20, 0.5, -8) or UDim2.new(0, 4, 0.5, -8)
    dot.Size = UDim2.new(0, 16, 0, 16)
    dot.BackgroundColor3 = default and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(200, 200, 205)
    local dCorner = Instance.new("UICorner")
    dCorner.CornerRadius = UDim.new(1, 0)
    dCorner.Parent = dot

    local state = default
    container.MouseButton1Click:Connect(function()
        state = not state
        TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(45, 45, 50)}):Play()
        TweenService:Create(dot, TweenInfo.new(0.2), {Position = state and UDim2.new(1, -20, 0.5, -8) or UDim2.new(0, 4, 0.5, -8)}):Play()
        dot.BackgroundColor3 = state and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(200, 200, 205)
        callback(state)
    end)
end

