local function createSlider(parent, config)
    local sliderFrame = Instance.new("Frame", parent)
    sliderFrame.Size = UDim2.new(1, 0, 0, 45)
    sliderFrame.BackgroundTransparency = 1
    local title = Instance.new("TextLabel", sliderFrame)
    title.Size = UDim2.new(1, 0, 0, 15)
    title.BackgroundTransparency = 1
    title.Font = Enum.Font.Gotham
    title.TextSize = 12
    title.TextColor3 = Color3.fromRGB(200, 200, 200)
    title.Text = config.Title
    local valueLabel = Instance.new("TextLabel", sliderFrame)
    valueLabel.Size = UDim2.new(1, 0, 0, 15)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 12
    valueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    local bg = Instance.new("Frame", sliderFrame)
    bg.Size = UDim2.new(1, 0, 0, 6)
    bg.Position = UDim2.new(0, 0, 0, 28)
    bg.BackgroundColor3 = Color3.fromRGB(45, 45, 48)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 4)
    local fill = Instance.new("Frame", bg)
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 4)
    local currentVal = config.Default or config.Min
    local function update(input)
        local pos = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        local val = config.Min + (config.Max - config.Min) * pos
        if config.Step then val = math.round(val / config.Step) * config.Step end
        val = math.clamp(val, config.Min, config.Max)
        currentVal = val
        fill.Size = UDim2.new((val - config.Min) / (config.Max - config.Min), 0, 1, 0)
        valueLabel.Text = string.format(config.Format or "%.1f", val)
        if config.Changed then config.Changed(val) end
    end
    local dragging = false
    bg.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true update(input) end end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    UserInputService.InputChanged:Connect(function(input) if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update(input) end end)
    return {SetValue = function(v) currentVal = v fill.Size = UDim2.new((v - config.Min) / (config.Max - config.Min), 0, 1, 0) valueLabel.Text = string.format(config.Format or "%.1f", v) if config.Changed then config.Changed(v) end end}
end

