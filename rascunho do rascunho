local tokensRoda = {
    FL = {"FL","FRONTLEFT","FRONT_LEFT","LEFTFRONT","LEFT_FRONT"},
    FR = {"FR","FRONTRIGHT","FRONT_RIGHT","RIGHTFRONT","RIGHT_FRONT"},
    RL = {"RL","REARLEFT","REAR_LEFT","LEFTREAR","LEFT_REAR","BACKLEFT","BACK_LEFT"},
    RR = {"RR","REARRIGHT","REAR_RIGHT","RIGHTREAR","RIGHT_REAR","BACKRIGHT","BACK_RIGHT"},
}

local function tagDaRoda(nomeUpper)
    for tag, lista in pairs(tokensRoda) do
        for _, t in ipairs(lista) do
            if nomeUpper:find(t, 1, true) then
                return tag
            end
        end
    end
    return nil
end

local function clamp(n, a, b)
    if n < a then return a end
    if n > b then return b end
    return n
end

