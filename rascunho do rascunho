-- Botão: Rastrear Jogador Específico
createButton(trackerSection, "Rastrear Jogador Específico", function()
    local nome = playerInput.Text
    if nome == nil or nome == "" then
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = "Tracker",
                Text = "Digite o nome do jogador no campo acima",
                Duration = 3
            })
        end)
        return
    end

    -- Verifica se o jogador existe na partida
    local encontrado = nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower() == nome:lower() then
            encontrado = p
            break
        end
    end

    if not encontrado then
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = "Tracker",
                Text = "Jogador '" .. nome .. "' não encontrado na partida",
                Duration = 3
            })
        end)
        return
    end

    pararTracker()
    trackerAlvoNome = encontrado.Name
    iniciarTracker()
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "Tracker Ativado",
            Text = "Rastreando: " .. encontrado.Name,
            Duration = 3
        })
    end)
end)

-- Botão: Teleportar para Frente do Jogador
createButton(trackerSection, "Teleportar para Frente", function()
    local nome = playerInput.Text
    local alvoNome = (nome ~= nil and nome ~= "") and nome or trackerAlvoNome

    if not alvoNome then
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = "Teleporte",
                Text = "Digite o nome do jogador ou ative o tracker primeiro",
                Duration = 3
            })
        end)
        return
    end

    local alvo = nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower() == alvoNome:lower() then
            alvo = p
            break
        end
    end

    if not alvo then
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = "Teleporte",
                Text = "Jogador não encontrado na partida",
                Duration = 3
            })
        end)
        return
    end

    local alvoChar = alvo.Character
    if not alvoChar then
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = "Teleporte",
                Text = "Personagem do alvo não encontrado",
                Duration = 3
            })
        end)
        return
    end

    local alvoHRP = alvoChar:FindFirstChild("HumanoidRootPart")
    if not alvoHRP then return end

    local myChar = player.Character
    if not myChar then return end
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    -- Teleporta 3 studs na frente do alvo
    local offset = alvoHRP.CFrame.LookVector * 3
    myHRP.CFrame = CFrame.new(alvoHRP.Position + offset + Vector3.new(0, 0.5, 0))

    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "Teleportado!",
            Text = "Você foi teleportado para frente de " .. alvo.Name,
            Duration = 3
        })
    end)
end)

