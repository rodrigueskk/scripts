-- Função para criar Slider Simples
local function createSlider(name, min, max, pos, callback)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.9, 0, 0, 20)
    label.Position = pos
    label.Text = name .. ": 0"
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.Parent = main

    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(0.9, 0, 0, 6)
    sliderBg.Position = pos + UDim2.new(0, 0, 0, 25)
    sliderBg.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    sliderBg.Parent = main
    Instance.new("UICorner", sliderBg)

    local knob = Instance.new("TextButton")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new(0.5, 0, 0.5, 0)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Text = ""
    knob.Parent = sliderBg
    Instance.new("UICorner", knob)

    local dragging = false
    knob.MouseButton1Down:Connect(function() dragging = true end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    RunService.RenderStepped:Connect(function()
        if dragging then
            local mousePos = UserInputService:GetMouseLocation().X
            local relativePos = (mousePos - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X
            relativePos = math.clamp(relativePos, 0, 1)
            knob.Position = UDim2.new(relativePos, 0, 0.5, 0)
            
            local value = min + (max - min) * relativePos
            label.Text = string.format("%s: %.2f", name, value)
            callback(value)
        end
    end)
end

