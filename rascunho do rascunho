-- Configurações e Tags das Rodas
local tokensRoda = {
    FL = {"FL","FRONTLEFT","FRONT_LEFT","LEFTFRONT","LEFT_FRONT"},
    FR = {"FR","FRONTRIGHT","FRONT_RIGHT","RIGHTFRONT","RIGHT_FRONT"},
    RL = {"RL","REARLEFT","REAR_LEFT","LEFTREAR","LEFT_REAR","BACKLEFT","BACK_LEFT"},
    RR = {"RR","REARRIGHT","REAR_RIGHT","RIGHTREAR","RIGHT_REAR","BACKRIGHT","BACK_RIGHT"},
}

local function tagDaRoda(nomeUpper)
    for tag, lista in pairs(tokensRoda) do
        for _, t in ipairs(lista) do
            if nomeUpper:find(t, 1, true) then
                return tag
            end
        end
    end
    return nil
end

local function getVehicle()
    local character = player.Character
    if not character then return nil end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return nil end
    local seatPart = humanoid.SeatPart
    if not seatPart then return nil end
    return seatPart:FindFirstAncestorOfClass("Model")
end

-- Cache para armazenar a posição original dos Attachments
local originalOffsets = {}

-- Função de Espaçador (Offset)
local function aplicarEspaçador(valor)
    local vehicle = getVehicle()
    if not vehicle then return end
    
    for _, d in ipairs(vehicle:GetDescendants()) do
        if d:IsA("Attachment") then
            local tag = tagDaRoda(string.upper(d.Parent.Name)) or tagDaRoda(string.upper(d.Name))
            if tag then
                if not originalOffsets[d] then originalOffsets[d] = d.Position end
                
                local pos = originalOffsets[d]
                local offset = valor
                
                -- Lógica: FL e RL para direita (X positivo), FR e RR para esquerda (X negativo) para fechar (dentro)
                -- Se o valor for positivo (direita no slider), move para dentro. Negativo para fora.
                if tag == "FL" or tag == "RL" then
                    d.Position = Vector3.new(pos.X + offset, pos.Y, pos.Z)
                elseif tag == "FR" or tag == "RR" then
                    d.Position = Vector3.new(pos.X - offset, pos.Y, pos.Z)
                end
            end
        end
    end
end

-- Função de Camber (Inclinação)
local function aplicarCamber(graus)
    local vehicle = getVehicle()
    if not vehicle then return end
    
    for _, d in ipairs(vehicle:GetDescendants()) do
        if d:IsA("Attachment") then
            local tag = tagDaRoda(string.upper(d.Parent.Name)) or tagDaRoda(string.upper(d.Name))
            if tag then
                local rad = math.rad(graus)
                -- Inverte para o lado oposto para manter simetria
                if tag == "FR" or tag == "RR" then
                    d.Orientation = Vector3.new(d.Orientation.X, d.Orientation.Y, -graus)
                else
                    d.Orientation = Vector3.new(d.Orientation.X, d.Orientation.Y, graus)
                end
            end
        end
    end
end

