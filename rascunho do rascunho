local function createSlider(parent, options)
    local title = options.Title or "Slider"
    local min = options.Min or 0
    local max = options.Max or 100
    local step = options.Step or 1
    local default = options.Default or min
    local format = options.Format or "%.0f"
    local changed = options.Changed or function() end

    local container = Instance.new("Frame")
    container.Parent = parent
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 48)

    local sTitle = Instance.new("TextLabel")
    sTitle.Parent = container
    sTitle.BackgroundTransparency = 1
    sTitle.Size = UDim2.new(1, 0, 0, 16)
    sTitle.Font = Enum.Font.GothamMedium
    sTitle.TextSize = 13
    sTitle.TextColor3 = Color3.fromRGB(220, 220, 225)
    sTitle.Text = title
    sTitle.TextXAlignment = Enum.TextXAlignment.Left

    local valLabel = Instance.new("TextLabel")
    valLabel.Parent = container
    valLabel.BackgroundTransparency = 1
    valLabel.Size = UDim2.new(1, 0, 0, 16)
    valLabel.Font = Enum.Font.GothamMedium
    valLabel.TextSize = 13
    valLabel.TextColor3 = Color3.fromRGB(150, 150, 155)
    valLabel.Text = string.format(format, default)
    valLabel.TextXAlignment = Enum.TextXAlignment.Right

    local bg = Instance.new("Frame")
    bg.Parent = container
    bg.Position = UDim2.new(0, 0, 0, 26)
    bg.Size = UDim2.new(1, 0, 0, 6)
    bg.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    bg.BorderSizePixel = 0

    local bgCorner = Instance.new("UICorner")
    bgCorner.CornerRadius = UDim.new(0, 4)
    bgCorner.Parent = bg

    local fill = Instance.new("Frame")
    fill.Parent = bg
    fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    fill.BorderSizePixel = 0

    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(0, 4)
    fillCorner.Parent = fill

    local dragging = false
    local currentValue = default

    local function update(input)
        local pos = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        currentValue = min + (max - min) * pos
        if step > 0 then
            currentValue = math.floor(currentValue / step + 0.5) * step
        end
        currentValue = math.clamp(currentValue, min, max)
        
        fill.Size = UDim2.new((currentValue - min) / (max - min), 0, 1, 0)
        valLabel.Text = string.format(format, currentValue)
        changed(currentValue)
    end

    bg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            update(input)
        end
    end)

    local function setValue(v)
        currentValue = math.clamp(v, min, max)
        fill.Size = UDim2.new((currentValue - min) / (max - min), 0, 1, 0)
        valLabel.Text = string.format(format, currentValue)
        changed(currentValue)
    end

    setValue(currentValue)

    return {
        SetValue = setValue
    }
end

