    nameLabel.TextSize = 13
    nameLabel.TextColor3 = (trackerAlvoNome and targetPlayer.Name:lower() == trackerAlvoNome:lower()) and COR_ALVO or COR_TODOS
    nameLabel.Text = "👤 " .. targetPlayer.Name
    nameLabel.TextTruncate = Enum.TextTruncate.AtEnd

    trackerLabels[targetPlayer.Name] = bb
end

local function removerLabel(playerName)
    if trackerLabels[playerName] then
        pcall(function() trackerLabels[playerName]:Destroy() end)
        trackerLabels[playerName] = nil
    end
end

local function removerTodasLabels()
    for name, _ in pairs(trackerLabels) do
        removerLabel(name)
    end
end

local function iniciarTracker()
    trackerAtivo = true

    -- Criar labels para jogadores já na partida
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            local deveRastrear = (trackerAlvoNome == nil) or (p.Name:lower() == trackerAlvoNome:lower())
            if deveRastrear then
                if p.Character then
                    criarLabel(p)
                end
                -- Quando o personagem spawnar
                p.CharacterAdded:Connect(function()
                    if trackerAtivo then
                        task.wait(0.5)
                        local deveAinda = (trackerAlvoNome == nil) or (p.Name:lower() == trackerAlvoNome:lower())
                        if deveAinda then
                            criarLabel(p)
                        end
                    end
                end)
                p.CharacterRemoving:Connect(function()
                    removerLabel(p.Name)
                end)
            end
        end
    end

    -- Novos jogadores que entram durante o tracker
    Players.PlayerAdded:Connect(function(p)
        if trackerAtivo and p ~= player then
            local deveRastrear = (trackerAlvoNome == nil) or (p.Name:lower() == trackerAlvoNome:lower())
            if deveRastrear then
                p.CharacterAdded:Connect(function()
                    if trackerAtivo then
                        task.wait(0.5)
                        criarLabel(p)
                    end
                end)
                p.CharacterRemoving:Connect(function()
                    removerLabel(p.Name)
                end)
            end
        end
    end)

    Players.PlayerRemoving:Connect(function(p)
        removerLabel(p.Name)
    end)
end

local function pararTracker()
    trackerAtivo = false
    trackerAlvoNome = nil
    removerTodasLabels()
end

