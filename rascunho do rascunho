        for i = chatViewStart-1, novoStart, -1 do
            local row = criarLinhaMsg(chatMessages[i]); row.LayoutOrder = i
        end
        chatViewStart = novoStart
        loadMoreLbl.Text = chatViewStart > 1 and ("↑ Ver mais ("..(chatViewStart-1).." anteriores)") or "— Início do histórico —"
        task.wait(); local delta = scroll.AbsoluteCanvasSize.Y - prevCanvas
        scroll.CanvasPosition = Vector2.new(0, scroll.CanvasPosition.Y + delta)
    end)

    for i = chatViewStart, #chatMessages do
