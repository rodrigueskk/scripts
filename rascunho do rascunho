    bgCorner.CornerRadius = UDim.new(0, 8)
    bgCorner.Parent = bg

    local bgStroke = Instance.new("UIStroke")
    bgStroke.Parent = bg
    bgStroke.Thickness = 1.2
    bgStroke.Color = (trackerAlvoNome and targetPlayer.Name:lower() == trackerAlvoNome:lower()) and COR_ALVO or COR_TODOS
    bgStroke.Transparency = 0.1

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Parent = bg
    nameLabel.Size = UDim2.new(1, -8, 1, 0)
    nameLabel.Position = UDim2.new(0, 4, 0, 0)
