local function isAmigo(targetPlayer)
    local ok, result = pcall(function()
        return player:IsFriendsWith(targetPlayer.UserId)
    end)
    return ok and result
end

local function capturarMsgBackground(msg)
    local sender = msg.TextSource
    if not sender then return end
    local sP  = Players:GetPlayerByUserId(sender.UserId)
    local nome = sP and sP.Name        or tostring(sender.UserId)
    local dn   = sP and sP.DisplayName or nome
    local ami  = sP and isAmigo(sP)    or false
    local txt  = msg.Text              or ""
    table.insert(chatMessages, {nome=nome, displayName=dn, mensagem=txt, isAmigo=ami})
    if #chatMessages > 500 then table.remove(chatMessages, 1) end
end

