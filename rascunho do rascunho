    label.Text = text
    label.TextXAlignment = Enum.TextXAlignment.Left
    if desc then
        local descLabel = Instance.new("TextLabel", frame)
        descLabel.Size = UDim2.new(0.8, 0, 0, 15)
        descLabel.Position = UDim2.new(0, 0, 0, 20)
        descLabel.BackgroundTransparency = 1
        descLabel.Font = Enum.Font.Gotham
        descLabel.TextSize = 11
        descLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
        descLabel.Text = desc
        descLabel.TextXAlignment = Enum.TextXAlignment.Left
    end
    local box = Instance.new("TextButton", frame)
    box.Size = UDim2.new(0, 22, 0, 22)
    box.Position = UDim2.new(1, -22, 0, 4)
    box.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    box.Text = ""
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", box).Color = Color3.fromRGB(255, 0, 0)
    local check = Instance.new("Frame", box)
    check.Size = UDim2.new(0, 0, 0, 0)
    check.Position = UDim2.new(0.5, 0, 0.5, 0)
    check.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", check).CornerRadius = UDim.new(0, 4)
    local function update(state)
        if state then
            TweenService:Create(check, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0.7, 0, 0.7, 0), Position = UDim2.new(0.15, 0, 0.15, 0)}):Play()
        else
            TweenService:Create(check, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
        end
        configData[key] = state
        saveConfig()
        if callback then callback(state) end
    end
    box.MouseButton1Click:Connect(function() update(not configData[key]) end)
    update(configData[key])
end

