-- Helper: salva tema em StringValue no PlayerGui
local function salvarTema()
    local HttpService = game:GetService("HttpService")
    local function c(col)
        return {math.floor(col.R*255), math.floor(col.G*255), math.floor(col.B*255)}
    end
    local json = HttpService:JSONEncode({
        p = c(tema.primaria),
        s = c(tema.secundaria),
        t = c(tema.terciaria),
        q = c(tema.quaternaria),
    })
    -- Salva em StringValue (memória da sessão)
    local sv = playerGui:FindFirstChild("__ComitHubTema")
    if not sv then
        sv = Instance.new("StringValue")
        sv.Name = "__ComitHubTema"
        sv.Parent = playerGui
    end
    sv.Value = json
    -- Salva em arquivo (persiste entre sessões - Xeno e outros executores)
    pcall(function() writefile("ComitHub_tema.json", json) end)
end

-- Cor de section = primária levemente mais escura (fator 0.75)
local function sectionColor()
    local r = math.clamp(tema.primaria.R * 0.75, 0, 1)
    local g = math.clamp(tema.primaria.G * 0.75, 0, 1)
    local b = math.clamp(tema.primaria.B * 0.75, 0, 1)
    -- garante mínimo de escuridão visível
    if r < 0.04 and g < 0.04 and b < 0.04 then
        r, g, b = 0.07, 0.07, 0.08
    end
    return Color3.new(r, g, b)
end

-- Aplica o tema em todos os elementos da UI
local function aplicarTema()
    local secCor = sectionColor()
    -- Primária: fundo do main, settingsPanel, openButton
    main.BackgroundColor3           = tema.primaria
    openButton.BackgroundColor3     = tema.primaria
    -- settingsPanel também muda
    if settingsPanel then settingsPanel.BackgroundColor3 = tema.primaria end
    -- Sections (fundo levemente mais escuro que primária)
    for _, s in ipairs(allSections) do
        pcall(function() s.BackgroundColor3 = secCor end)
    end
    -- Terciária: textos principais
    openButton.TextColor3  = tema.terciaria
    title.TextColor3       = tema.terciaria
    -- Quaternária: knobs e fills de sliders
    for _, k in ipairs(allSliderKnobs) do pcall(function() k.BackgroundColor3 = tema.quaternaria end) end
    for _, f in ipairs(allSliderFills) do pcall(function() f.BackgroundColor3 = tema.quaternaria end) end
    for _, b in ipairs(allButtons) do
        pcall(function()
            b.BackgroundColor3 = tema.primaria
            b.TextColor3 = tema.terciaria
        end)
    end

    -- Aplica tema no chatHub se estiver aberto
    if chatHubGui and chatHubGui.Parent then
        local chatWin = chatHubGui:FindFirstChildWhichIsA("Frame")
        if chatWin then
            -- Fundo da janela = primária levemente mais escura
            local r = math.max(0, tema.primaria.R - 0.04)
            local g = math.max(0, tema.primaria.G - 0.04)
            local b = math.max(0, tema.primaria.B - 0.04)
            chatWin.BackgroundColor3 = Color3.new(r, g, b)
            -- Topbar = primária pura
            local tb = chatWin:FindFirstChildWhichIsA("Frame")
            if tb then tb.BackgroundColor3 = tema.primaria end
            -- cfgPanel = primária levemente mais clara
            for _, child in ipairs(chatWin:GetChildren()) do
                if child:IsA("Frame") and child.Name == "" and child.ZIndex == 500 then
                    child.BackgroundColor3 = Color3.new(
                        math.min(1, tema.primaria.R + 0.03),
                        math.min(1, tema.primaria.G + 0.03),
                        math.min(1, tema.primaria.B + 0.05)
                    )
                end
            end
        end
    end
end

