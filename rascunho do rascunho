-- ============================================================
RunService.Stepped:Connect(function()
    local vehicle = getVehicle()
    if not vehicle then return end
    local seat = getVehicleSeat(vehicle)
    if not seat then return end

    -- Multiplicador de Velocidade (W)
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
        seat.AssemblyLinearVelocity *= Vector3.new(1 + velocityMult, 1, 1 + velocityMult)
    end

    -- Multiplicador de Frenagem (S)
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
        seat.AssemblyLinearVelocity *= Vector3.new(1 - velocityMult2, 1, 1 - velocityMult2)
    end
end)

