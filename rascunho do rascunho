local function iniciarTracker()
    trackerAtivo = true

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            local deveRastrear = (trackerAlvoNome == nil) or eAlvo(p)
            if deveRastrear then
                if p.Character then
                    criarLabel(p)
                end
                p.CharacterAdded:Connect(function()
                    if trackerAtivo then
                        task.wait(0.5)
                        if (trackerAlvoNome == nil) or eAlvo(p) then
                            criarLabel(p)
                        end
                    end
                end)
                p.CharacterRemoving:Connect(function()
                    removerLabel(p.Name)
                end)
            end
        end
    end

    Players.PlayerAdded:Connect(function(p)
        if trackerAtivo and p ~= player then
            local deveRastrear = (trackerAlvoNome == nil) or eAlvo(p)
            if deveRastrear then
                p.CharacterAdded:Connect(function()
                    if trackerAtivo then
                        task.wait(0.5)
                        criarLabel(p)
                    end
                end)
                p.CharacterRemoving:Connect(function()
                    removerLabel(p.Name)
                end)
            end
        end
    end)

    Players.PlayerRemoving:Connect(function(p)
        removerLabel(p.Name)
    end)
end

local function pararTracker()
    trackerAtivo = false
    trackerAlvoNome = nil
    removerTodasLabels()
end

