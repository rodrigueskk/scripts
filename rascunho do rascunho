    local minhaBubble = nil
    local function mostrarMinhaBubble(texto)
        if minhaBubble then pcall(function() minhaBubble:Destroy() end) end
        local myChar = player.Character; if not myChar then return end
        local hrp = myChar:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        minhaBubble = Instance.new("BillboardGui"); minhaBubble.Adornee = hrp
