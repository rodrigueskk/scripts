createButton(trackerSection, "Teleportar para Frente", function()
    local nome = playerInput.Text
    local alvo = nil

    -- Prioridade: campo de texto → alvo ativo do tracker
    local textoBusca = (nome and nome ~= "") and nome or trackerAlvoNome

    if not textoBusca then
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = "Teleporte",
                Text = "Digite o username ou nome de exibição, ou ative o tracker primeiro",
                Duration = 3
            })
        end)
        return
    end

    -- buscarJogador aceita username E DisplayName
    alvo = buscarJogador(textoBusca)

    -- fallback: se buscarJogador não achar (ex: trackerAlvoNome já é username exato)
    if not alvo then
        local t = textoBusca:lower()
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and (p.Name:lower() == t or p.DisplayName:lower() == t) then
                alvo = p
                break
            end
        end
    end

    if not alvo then
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = "Teleporte",
                Text = "Jogador '" .. textoBusca .. "' não encontrado",
                Duration = 3
            })
        end)
        return
    end

    local alvoChar = alvo.Character
    if not alvoChar then
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = "Teleporte",
                Text = "Personagem do alvo não encontrado",
                Duration = 3
            })
        end)
        return
    end

    local alvoHRP = alvoChar:FindFirstChild("HumanoidRootPart")
    if not alvoHRP then return end

    local myChar = player.Character
    if not myChar then return end
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    local offset = alvoHRP.CFrame.LookVector * 3
    myHRP.CFrame = CFrame.new(alvoHRP.Position + offset + Vector3.new(0, 0.5, 0))

    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "Teleportado!",
            Text = "Você foi para frente de " .. alvo.DisplayName .. " (@" .. alvo.Name .. ")",
            Duration = 3
        })
