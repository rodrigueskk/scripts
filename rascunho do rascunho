-- ============================================================
-- LÓGICA DE COMPARTILHAR DADOS: reaplicar ao entrar no carro
-- ============================================================

local function reaplicarConfigs()
    local vehicle = getVehicle()
    if not vehicle then return end
    applyLocalSuspension(savedConfig.suspension)
    velocityMult  = savedConfig.speed  / 1000
    velocityMult2 = savedConfig.brake  / 1000
    applyTireGrip(vehicle, savedConfig.grip)
end

local character = player.Character or player.CharacterAdded:Wait()

local function monitorarAssento(char)
    local humanoid = char:WaitForChild("Humanoid", 10)
    if not humanoid then return end
    humanoid:GetPropertyChangedSignal("SeatPart"):Connect(function()
        if compartilharDados and humanoid.SeatPart then
            task.wait(0.3)
            reaplicarConfigs()
        end
    end)
end

monitorarAssento(character)
player.CharacterAdded:Connect(function(char)
    monitorarAssento(char)
end)

