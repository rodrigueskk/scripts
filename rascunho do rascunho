-- Loop de Monitoramento e Movimento
local lastVehicle = nil
RunService.Heartbeat:Connect(function()
    local vehicle = getVehicle()
    if vehicle ~= lastVehicle then
        if lastVehicle and not compartilhamentoAtivo then
            resetarCarro(lastVehicle)
        end
        if vehicle and compartilhamentoAtivo then
            local saved = configuracoesSalvas[vehicle]
            if saved then
                currentSuspension = saved.suspension
                velocityMult = saved.speed
                velocityMult2 = saved.brake
                applyLocalSuspension(currentSuspension, vehicle)
                applyTireGrip(vehicle, saved.grip)
                suspensionSlider.SetValue(currentSuspension)
            else
                salvarConfiguracoes(vehicle)
            end
        end
        lastVehicle = vehicle
    end
end)

RunService.Stepped:Connect(function()
    local vehicle = getVehicle()
    if not vehicle then return end
    local seat = getVehicleSeat(vehicle)
    if not seat then return end

    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
        seat.AssemblyLinearVelocity *= Vector3.new(1 + velocityMult, 1, 1 + velocityMult)
    end

    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
        seat.AssemblyLinearVelocity *= Vector3.new(1 - velocityMult2, 1, 1 - velocityMult2)
    end
end)

