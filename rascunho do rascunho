-- ============================================================
-- RUNSERVICE: FÍSICA + FPS + ESP + ANTI-FLIP + ANTI-VOO + TRACKER
-- ============================================================
local fpsFrameCount = 0
local fpsTimer      = 0
local fpsESPTimer   = 0

RunService.Stepped:Connect(function(_, dt)
    local vehicle = getVehicle()
    atualizarCorTime()

    -- FPS Counter
    local fpsOn = Rayfield.Flags.FPSCounter and Rayfield.Flags.FPSCounter.CurrentValue
    fpsLabel.Visible = fpsOn or false
    if fpsOn then
        fpsFrameCount = fpsFrameCount + 1; fpsTimer = fpsTimer + dt
        if fpsTimer >= 0.5 then
            local fps = math.floor(fpsFrameCount / fpsTimer)
            fpsLabel.Text = "FPS: "..fps
            fpsLabel.TextColor3 = fps > 50 and Color3.fromRGB(0,220,100)
                or (fps > 25 and Color3.fromRGB(255,200,0) or Color3.fromRGB(220,60,60))
            fpsFrameCount = 0; fpsTimer = 0
        end
    end

    -- ESP de veículos
    if espAtivo then
        fpsESPTimer = fpsESPTimer + dt
        if fpsESPTimer >= 3 then fpsESPTimer = 0; escanearVeiculos() end
    end

    if not vehicle then return end
    local seat = getVehicleSeat(vehicle)
    if not seat then return end

    -- Velocidade (W)
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
        seat.AssemblyLinearVelocity = seat.AssemblyLinearVelocity * Vector3.new(1 + velocityMult, 1, 1 + velocityMult)
    end
    -- Frenagem (S)
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
        seat.AssemblyLinearVelocity = seat.AssemblyLinearVelocity * Vector3.new(1 - velocityMult2, 1, 1 - velocityMult2)
    end

    -- Compartilhar Dados
    if compartilharDados and outroJogadorNoVeiculo(vehicle) then
        applyLocalSuspension(savedConfig.suspension)
        applyTireGrip(vehicle, savedConfig.grip)
    end

    -- Anti-Flip
    if antiFlipAtivo then
        local upVec = seat.CFrame.UpVector
        if upVec.Y < 0.3 then
            pcall(function()
                seat.AssemblyAngularVelocity = Vector3.zero
                local pos = seat.Position
                seat.CFrame = CFrame.new(pos + Vector3.new(0,3,0))
                    * CFrame.Angles(0, math.atan2(seat.CFrame.LookVector.X, seat.CFrame.LookVector.Z), 0)
            end)
        end
    end

    -- Anti-Voo
    if antivooAtivo then
        local vel = seat.AssemblyLinearVelocity
        local velH = Vector3.new(vel.X,0,vel.Z).Magnitude
        if velH > 195 and vel.Y > 1 then
            pcall(function() seat.AssemblyLinearVelocity = Vector3.new(vel.X,0,vel.Z) end)
        end
    end
end)

-- ============================================================
-- ANTI-FLING (RenderStepped)
-- ============================================================
RunService.RenderStepped:Connect(function(dt)
    if not antiFlingAtivo then return end
    if getVehicle() then return end
    local char = player.Character; if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    if hum.Health <= 0 then antiFlingLastPos = nil; return end
    local ok, vel = pcall(function() return hrp.AssemblyLinearVelocity end)
    if not ok then return end
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {char}
    local ray = workspace:Raycast(hrp.Position, Vector3.new(0,-(FLING_CHAO_MAX+2),0), rayParams)
    local noChao = (ray ~= nil) and ((hrp.Position.Y - ray.Position.Y) <= FLING_CHAO_MAX)
    if noChao and math.abs(vel.Y) < 8 then antiFlingLastPos = hrp.CFrame end
    if math.abs(vel.Y) > FLING_VEL_LIMIT then
        pcall(function()
            hrp.AssemblyLinearVelocity  = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            if antiFlingLastPos then
                hrp.CFrame = antiFlingLastPos
            else
                local fallback = workspace:Raycast(hrp.Position, Vector3.new(0,-500,0), rayParams)
                if fallback then
                    local oriCF = hrp.CFrame - hrp.CFrame.Position
                    hrp.CFrame = CFrame.new(fallback.Position + Vector3.new(0,3,0)) * oriCF
                end
            end
        end)
        antiFlingToastTimer = antiFlingToastTimer + dt
        if antiFlingToastTimer >= 2 then
            antiFlingToastTimer = 0
            notify("Anti-Fling", "Fling bloqueado!", 2)
        end
    else
        antiFlingToastTimer = antiFlingToastTimer + dt
    end
end)

