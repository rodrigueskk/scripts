-- Lógica de Backfire
local function createFire(part)
    local fire = Instance.new("ParticleEmitter")
    fire.Name = "BackfireEffect"
    fire.Texture = "rbxassetid://242202417"
    fire.Color = ColorSequence.new(Color3.fromRGB(255, 120, 0), Color3.fromRGB(255, 50, 0))
    fire.Rate = 100
    fire.Speed = NumberRange.new(5, 10)
    fire.Lifetime = NumberRange.new(0.1, 0.3)
    fire.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0)})
    fire.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1)})
    fire.Enabled = false
    fire.Parent = part
    return fire
end

local lastVehicle = nil
local exhaustParticles = {}

RunService.Heartbeat:Connect(function()
    if not backfireEnabled then 
        for _, p in pairs(exhaustParticles) do p.Enabled = false end
        return 
    end

    local vehicle = getVehicle()
    if vehicle ~= lastVehicle then
        exhaustParticles = {}
        lastVehicle = vehicle
        if vehicle then
            local body = vehicle:FindFirstChild("Body") or vehicle:FindFirstChild("body")
            if body then
                for _, obj in ipairs(body:GetDescendants()) do
                    if obj.Name == "Exhaust" and obj:IsA("BasePart") then
                        table.insert(exhaustParticles, createFire(obj))
                    end
                end
            end
        end
    end

    if vehicle then
        local seat = getVehicleSeat(vehicle)
        if seat then
            local rpm = seat.PlaybackSpeed or (seat.AssemblyLinearVelocity.Magnitude / 10) -- Estimativa se não houver RPM real
            -- Se o jogo usar um sistema de RPM específico, o usuário pode ajustar aqui.
            -- Usando magnitude como base para o exemplo de > 5
            local isBackfiring = seat.AssemblyLinearVelocity.Magnitude > 50 -- Exemplo: velocidade alta simula RPM > 5
            
            for _, p in pairs(exhaustParticles) do
                p.Enabled = isBackfiring
            end
        end
    end
end)

RunService.Stepped:Connect(function()
    local vehicle = getVehicle()
    if not vehicle then return end
    local seat = getVehicleSeat(vehicle)
    if not seat then return end
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then seat.AssemblyLinearVelocity *= Vector3.new(1 + velocityMult, 1, 1 + velocityMult) end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then seat.AssemblyLinearVelocity *= Vector3.new(1 - velocityMult2, 1, 1 - velocityMult2) end
end)

