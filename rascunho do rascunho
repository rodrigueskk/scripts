-- VARIÁVEIS GLOBAIS DE LÓGICA
-- ============================================================
local alturaMin    = 0.05
local alturaMax    = 8
local velocityMult  = 0.025
local velocityMult2 = 0.150
local currentSuspension = 0
local currentSpeed  = 25
local currentBrake  = 150
local currentGrip   = 1

local compartilharDados = true
local savedConfig = { suspension = 2.5, speed = 25, brake = 150, grip = 1 }

local tokensRoda = {
    FL = {"FL","FRONTLEFT","FRONT_LEFT","LEFTFRONT","LEFT_FRONT"},
    FR = {"FR","FRONTRIGHT","FRONT_RIGHT","RIGHTFRONT","RIGHT_FRONT"},
    RL = {"RL","REARLEFT","REAR_LEFT","LEFTREAR","LEFT_REAR","BACKLEFT","BACK_LEFT"},
    RR = {"RR","REARRIGHT","REAR_RIGHT","RIGHTREAR","RIGHT_REAR","BACKRIGHT","BACK_RIGHT"},
}

local function tagDaRoda(nomeUpper)
    for tag, lista in pairs(tokensRoda) do
        for _, t in ipairs(lista) do
            if nomeUpper:find(t, 1, true) then return tag end
        end
    end
    return nil
end

local function clamp(n, a, b)
    if n < a then return a end
    if n > b then return b end
    return n
end

local function notify(title, content, duration)
    Rayfield:Notify({ Title = title, Content = content, Duration = duration or 4, Image = "info" })
end

