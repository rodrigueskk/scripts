local trackerAtivo    = false
local trackerAlvoNome = nil
local trackerLabels   = {}
local trackerConnections = {}
local COR_TODOS = Color3.fromRGB(255,255,255)
local COR_ALVO  = Color3.fromRGB(0,220,120)

local function buscarJogador(texto)
    if not texto or texto == "" then return nil end
    local t = texto:lower()
    local melhor = nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            local u = p.Name:lower()
            local d = p.DisplayName:lower()
            if u == t or d == t then return p end
            if not melhor and (u:find(t,1,true) or d:find(t,1,true)) then melhor = p end
        end
    end
    return melhor
end

local function eAlvo(p)
    return trackerAlvoNome and p.Name:lower() == trackerAlvoNome:lower()
end

local function criarLabel(targetPlayer)
    if trackerLabels[targetPlayer.Name] then
        pcall(function() trackerLabels[targetPlayer.Name]:Destroy() end)
        trackerLabels[targetPlayer.Name] = nil
    end
    local character = targetPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local isAlvo = eAlvo(targetPlayer)
    local cor = isAlvo and COR_ALVO or COR_TODOS
    local dn = targetPlayer.DisplayName
    local un = targetPlayer.Name
    local labelText = (dn:lower() ~= un:lower()) and ("👤 "..dn.." (@"..un..")") or ("👤 "..un)
    local bb = Instance.new("BillboardGui")
    bb.Name = "TrackerLabel_"..un
    bb.Adornee = hrp; bb.AlwaysOnTop = true
    bb.Size = UDim2.new(0,200,0,36); bb.StudsOffset = Vector3.new(0,3.2,0)
    bb.Parent = playerGui
    local bg = Instance.new("Frame"); bg.Parent = bb
    bg.Size = UDim2.new(1,0,1,0); bg.BackgroundColor3 = Color3.fromRGB(17,17,19)
    bg.BackgroundTransparency = 0.25; bg.BorderSizePixel = 0
    local bgC = Instance.new("UICorner"); bgC.CornerRadius = UDim.new(0,8); bgC.Parent = bg
    local bgS = Instance.new("UIStroke"); bgS.Parent = bg; bgS.Thickness = 1.2; bgS.Color = cor; bgS.Transparency = 0.1
    local nameLabel = Instance.new("TextLabel"); nameLabel.Parent = bg
    nameLabel.Size = UDim2.new(1,-8,1,0); nameLabel.Position = UDim2.new(0,4,0,0)
    nameLabel.BackgroundTransparency = 1; nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 11; nameLabel.TextColor3 = cor; nameLabel.Text = labelText
    nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
    trackerLabels[un] = bb
end

local function removerLabel(playerName)
    if trackerLabels[playerName] then
        pcall(function() trackerLabels[playerName]:Destroy() end)
        trackerLabels[playerName] = nil
    end
end

local function removerTodasLabels()
    for name in pairs(trackerLabels) do removerLabel(name) end
end

local function iniciarTracker()
    trackerAtivo = true
    for _, c in ipairs(trackerConnections) do pcall(function() c:Disconnect() end) end
    trackerConnections = {}
    local function deveRastrear(p) return p ~= player and (trackerAlvoNome == nil or eAlvo(p)) end
    local function processarJogador(p)
        if not deveRastrear(p) then return end
        if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then criarLabel(p) end
        local c1 = p.CharacterAdded:Connect(function(char)
            if not trackerAtivo or not deveRastrear(p) then return end
            task.spawn(function()
                char:WaitForChild("HumanoidRootPart", 8); task.wait(0.3)
                if trackerAtivo and deveRastrear(p) then criarLabel(p) end
            end)
        end)
        local c2 = p.CharacterRemoving:Connect(function() removerLabel(p.Name) end)
        table.insert(trackerConnections, c1); table.insert(trackerConnections, c2)
    end
    for _, p in ipairs(Players:GetPlayers()) do processarJogador(p) end
    local c3 = Players.PlayerAdded:Connect(function(p)
        if not trackerAtivo then return end; task.wait(1); processarJogador(p)
    end)
    local c4 = Players.PlayerRemoving:Connect(function(p) removerLabel(p.Name) end)
    table.insert(trackerConnections, c3); table.insert(trackerConnections, c4)
    task.spawn(function()
        while trackerAtivo do
            task.wait(1)
            if not trackerAtivo then break end
            for _, p in ipairs(Players:GetPlayers()) do
                if deveRastrear(p) then
                    local temLabel = trackerLabels[p.Name] and trackerLabels[p.Name].Parent ~= nil
                    local hrp = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                    if hrp and not temLabel then criarLabel(p)
                    elseif temLabel and not hrp then removerLabel(p.Name) end
                end
            end
        end
    end)
end

local function pararTracker()
    trackerAtivo = false; trackerAlvoNome = nil
    for _, c in ipairs(trackerConnections) do pcall(function() c:Disconnect() end) end
    trackerConnections = {}; removerTodasLabels()
end

