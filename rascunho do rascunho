local function escanearVeiculos()
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and not espSelections[obj] then
            if obj:FindFirstChildWhichIsA("VehicleSeat", true) then criarESP(obj) end
        end
    end
    for vehicle, sb in pairs(espSelections) do
        if not vehicle.Parent then pcall(function() sb:Destroy() end); espSelections[vehicle] = nil end
    end
end

