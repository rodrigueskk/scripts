            local bypassLbl = Instance.new("TextLabel"); bypassLbl.Parent = row
            bypassLbl.BackgroundTransparency = 1; bypassLbl.Size = UDim2.new(1,0,0,12)
            bypassLbl.Font = Enum.Font.Gotham; bypassLbl.TextSize = 9
