local chatHubGui     = nil
local chatHubConn    = nil
local chatMessages   = {}
local chatConfirmarEnvio = false
local CHAT_PAGE      = 30
local CHAT_LOAD_MORE = 20

local function isAmigo(targetPlayer)
    local ok, result = pcall(function() return player:IsFriendsWith(targetPlayer.UserId) end)
    return ok and result
end

local function extrairTextoReal(msg)
    local txt = ""; local bypassed = false
    pcall(function() txt = msg.Text or "" end)
    if txt == "" or txt:match("^[#%s]+$") then
        for _, prop in ipairs({"Message","RawText","OriginalText","FilteredText"}) do
            pcall(function()
                local val = msg[prop]
                if val and val ~= "" and not val:match("^[#%s]+$") then txt = val; bypassed = true end
            end)
            if txt ~= "" and not txt:match("^[#%s]+$") then break end
        end
    end
    local isFiltered = txt:match("^[#%s]+$") or txt == ""
    return txt, bypassed, isFiltered
end

local function capturarMsgBackground(msg)
    local sender = msg.TextSource; if not sender then return end
    local sP  = Players:GetPlayerByUserId(sender.UserId)
    local nome = sP and sP.Name or tostring(sender.UserId)
    local dn   = sP and sP.DisplayName or nome
    local ami  = sP and isAmigo(sP) or false
    local txt, bypassed, isFiltered = extrairTextoReal(msg)
    if txt == "" then return end
    table.insert(chatMessages, {nome=nome, displayName=dn, mensagem=txt, isAmigo=ami, bypassed=bypassed, isFiltered=isFiltered})
    if #chatMessages > 500 then table.remove(chatMessages, 1) end
end

task.spawn(function()
    task.wait(2)
    TextChatService.MessageReceived:Connect(function(msg)
        if chatHubGui and chatHubGui.Parent then return end
        capturarMsgBackground(msg)
    end)
end)

