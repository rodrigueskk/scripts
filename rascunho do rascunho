-- Cor do highlight do alvo específico
local COR_TODOS = Color3.fromRGB(255, 255, 255)
local COR_ALVO  = Color3.fromRGB(0, 220, 120)

-- Busca jogador por username OU DisplayName (parcial, case-insensitive)
local function buscarJogador(texto)
    if not texto or texto == "" then return nil end
    local t = texto:lower()
    local melhor = nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            local username    = p.Name:lower()
            local displayName = p.DisplayName:lower()
            -- match exato primeiro
            if username == t or displayName == t then
                return p
            end
            -- match parcial como fallback
            if not melhor then
                if username:find(t, 1, true) or displayName:find(t, 1, true) then
                    melhor = p
                end
            end
        end
    end
    return melhor
end

-- Verifica se um player bate com o alvo salvo (username)
local function eAlvo(p)
    return trackerAlvoNome and p.Name:lower() == trackerAlvoNome:lower()
end

local function criarLabel(targetPlayer)
    -- Remove label anterior se existir
    if trackerLabels[targetPlayer.Name] then
        pcall(function() trackerLabels[targetPlayer.Name]:Destroy() end)
        trackerLabels[targetPlayer.Name] = nil
    end

    local character = targetPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local isAlvo = eAlvo(targetPlayer)
    local cor = isAlvo and COR_ALVO or COR_TODOS

    -- Monta texto: DisplayName + @username se forem diferentes
    local displayName = targetPlayer.DisplayName
    local username    = targetPlayer.Name
    local labelText
    if displayName:lower() ~= username:lower() then
        labelText = "👤 " .. displayName .. " (@" .. username .. ")"
    else
        labelText = "👤 " .. username
    end

    local bb = Instance.new("BillboardGui")
    bb.Name = "TrackerLabel_" .. username
    bb.Adornee = hrp
    bb.AlwaysOnTop = true
    bb.Size = UDim2.new(0, 200, 0, 36)
    bb.StudsOffset = Vector3.new(0, 3.2, 0)
    bb.Parent = playerGui

    local bg = Instance.new("Frame")
    bg.Parent = bb
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Color3.fromRGB(17, 17, 19)
    bg.BackgroundTransparency = 0.25
    bg.BorderSizePixel = 0

    local bgCorner = Instance.new("UICorner")
    bgCorner.CornerRadius = UDim.new(0, 8)
    bgCorner.Parent = bg

    local bgStroke = Instance.new("UIStroke")
    bgStroke.Parent = bg
    bgStroke.Thickness = 1.2
    bgStroke.Color = cor
    bgStroke.Transparency = 0.1

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Parent = bg
    nameLabel.Size = UDim2.new(1, -8, 1, 0)
    nameLabel.Position = UDim2.new(0, 4, 0, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 11
    nameLabel.TextColor3 = cor
    nameLabel.Text = labelText
    nameLabel.TextTruncate = Enum.TextTruncate.AtEnd

    trackerLabels[username] = bb
end

local function removerLabel(playerName)
    if trackerLabels[playerName] then
        pcall(function() trackerLabels[playerName]:Destroy() end)
        trackerLabels[playerName] = nil
    end
end

local function removerTodasLabels()
    for name, _ in pairs(trackerLabels) do
        removerLabel(name)
    end
end

local trackerConnections = {}

local function iniciarTracker()
    trackerAtivo = true

    for _, c in ipairs(trackerConnections) do
        pcall(function() c:Disconnect() end)
    end
    trackerConnections = {}

    local function deveRastrearP(p)
        return p ~= player and ((trackerAlvoNome == nil) or eAlvo(p))
    end

    local function processarJogador(p)
        if not deveRastrearP(p) then return end
        if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            criarLabel(p)
        end
        local c1 = p.CharacterAdded:Connect(function(char)
            if not trackerAtivo or not deveRastrearP(p) then return end
            task.spawn(function()
                char:WaitForChild("HumanoidRootPart", 8)
                task.wait(0.3)
                if trackerAtivo and deveRastrearP(p) then
                    criarLabel(p)
                end
            end)
        end)
        local c2 = p.CharacterRemoving:Connect(function()
            removerLabel(p.Name)
        end)
        table.insert(trackerConnections, c1)
        table.insert(trackerConnections, c2)
    end

    for _, p in ipairs(Players:GetPlayers()) do
        processarJogador(p)
    end

    local c3 = Players.PlayerAdded:Connect(function(p)
        if not trackerAtivo then return end
        task.wait(1)
        processarJogador(p)
    end)
    table.insert(trackerConnections, c3)

    local c4 = Players.PlayerRemoving:Connect(function(p)
        removerLabel(p.Name)
    end)
    table.insert(trackerConnections, c4)

    task.spawn(function()
        while trackerAtivo do
            task.wait(1)
            if not trackerAtivo then break end
            for _, p in ipairs(Players:GetPlayers()) do
                if deveRastrearP(p) then
                    local temLabel = trackerLabels[p.Name] and trackerLabels[p.Name].Parent ~= nil
                    local hrp = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                    if hrp and not temLabel then
                        criarLabel(p)
                    elseif temLabel and not hrp then
                        removerLabel(p.Name)
                    end
                end
            end
        end
    end)
end

local function pararTracker()
    trackerAtivo = false
    trackerAlvoNome = nil
    for _, c in ipairs(trackerConnections) do
        pcall(function() c:Disconnect() end)
    end
    trackerConnections = {}
    removerTodasLabels()
end

