local function saveConfig()
    if writefile then
        pcall(function()
            writefile(configFileName, HttpService:JSONEncode(configData))
        end)
    end
end

local function loadConfig()
    if readfile and isfile and isfile(configFileName) then
        pcall(function()
            local saved = HttpService:JSONDecode(readfile(configFileName))
            for k, v in pairs(saved) do configData[k] = v end
        end)
    end
end
