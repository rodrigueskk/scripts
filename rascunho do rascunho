createToggle(configSection, "Compartilhamento", compartilhamentoAtivo, function(v)
    compartilhamentoAtivo = v
    if not v then
        local vhc = getVehicle()
        if vhc then resetarCarro(vhc) end
    else
        local vhc = getVehicle()
        if vhc then salvarConfiguracoes(vhc) end
    end
end)

-- Sliders Originais (Simplificados para a lógica)
local function createSlider(parent, title, min, max, default, callback)
    local btn = Instance.new("TextButton")
    btn.Parent = parent
    btn.Size = UDim2.new(1, 0, 0, 40)
    btn.Text = title .. ": " .. default
    btn.MouseButton1Click:Connect(function()
        local novo = default + 0.5
        if novo > max then novo = min end
        default = novo
        btn.Text = title .. ": " .. default
        callback(novo)
        if compartilhamentoAtivo then salvarConfiguracoes(getVehicle()) end
    end)
end

createSlider(mainSection, "Suspensão", 0.05, 8, 2.5, function(v) 
    currentSuspension = v
    applyLocalSuspension(v) 
end)

-- Monitoramento de Mudança de Carro
local lastVehicle = nil
RunService.Heartbeat:Connect(function()
    local vehicle = getVehicle()
    if vehicle ~= lastVehicle then
        if lastVehicle and not compartilhamentoAtivo then
            resetarCarro(lastVehicle)
        end
        if vehicle and compartilhamentoAtivo then
            local saved = configuracoesSalvas[vehicle]
            if saved then
                currentSuspension = saved.suspension
                velocityMult = saved.speed
                velocityMult2 = saved.brake
                currentGrip = saved.grip
                applyLocalSuspension(currentSuspension, vehicle)
                applyTireGrip(vehicle, currentGrip)
            else
                salvarConfiguracoes(vehicle)
            end
        end
        lastVehicle = vehicle
    end
end)

-- Lógica de Movimento
RunService.Stepped:Connect(function()
    local vehicle = getVehicle()
    if not vehicle then return end
    local seat = getVehicleSeat(vehicle)
    if not seat then return end
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
        seat.AssemblyLinearVelocity *= Vector3.new(1 + velocityMult, 1, 1 + velocityMult)
    end
end)
