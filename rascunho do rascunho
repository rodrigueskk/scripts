        lbl2.TextColor3 = Color3.fromRGB(20,20,60); lbl2.Text = texto; lbl2.TextWrapped = true
        task.delay(6, function() pcall(function() minhaBubble:Destroy() end); minhaBubble = nil end)
    end

    local function enviarMensagem(texto)
        if texto == "" then return end
        pcall(function()
            local channels = TextChatService:FindFirstChild("TextChannels")
            if channels then
                local ch = channels:FindFirstChild("RBXGeneral") or channels:GetChildren()[1]
                if ch and ch:IsA("TextChannel") then ch:SendAsync(texto) end
            end
        end)
        mostrarMinhaBubble(texto); msgBox.Text = ""
    end

    local function tentarEnviar()
        local txt = msgBox.Text; if txt == "" then return end
        if chatConfirmarEnvio then
            -- confirmação simples via notificação
            notify("Confirmar Envio", "Mensagem: \""..txt.."\" — envie novamente para confirmar", 3)
            chatConfirmarEnvio = false
            task.delay(5, function() chatConfirmarEnvio = true end)
            enviarMensagem(txt)
        else
            enviarMensagem(txt)
        end
    end

    sendBtn.MouseButton1Click:Connect(tentarEnviar)
    msgBox.FocusLost:Connect(function(enterPressed) if enterPressed then tentarEnviar() end end)

    chatHubConn = TextChatService.MessageReceived:Connect(function(msg)
        local sender = msg.TextSource; if not sender then return end
        local sP  = Players:GetPlayerByUserId(sender.UserId)
        local nome = sP and sP.Name or tostring(sender.UserId)
        local dn   = sP and sP.DisplayName or nome
        local ami  = sP and isAmigo(sP) or false
        local txt, bypassed, isFiltered = extrairTextoReal(msg)
        if txt == "" then return end
        local dados = {nome=nome, displayName=dn, mensagem=txt, isAmigo=ami, bypassed=bypassed, isFiltered=isFiltered}
        table.insert(chatMessages, dados)
        if #chatMessages > 500 then table.remove(chatMessages, 1) end
        local row = criarLinhaMsg(dados); row.LayoutOrder = #chatMessages
        if usuarioScrollado then
            novasMensagens = novasMensagens + 1
            newMsgBadge.Text = "+ "..novasMensagens..(novasMensagens == 1 and " mensagem nova" or " mensagens novas")
            newMsgBadge.Visible = true
        else
            task.wait(); scroll.CanvasPosition = Vector2.new(0, scroll.AbsoluteCanvasSize.Y)
        end
    end)
end

