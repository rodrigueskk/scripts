local function createToggle(text, default, callback)
    local frame = Instance.new("Frame", settingsFrame)
    frame.Size = UDim2.new(0.9, 0, 0, 30)
    frame.BackgroundTransparency = 1
    
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(0.8, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamBold
    label.TextSize = 13
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.Text = text
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    local box = Instance.new("TextButton", frame)
    box.Size = UDim2.new(0, 22, 0, 22)
    box.Position = UDim2.new(1, -22, 0.5, -11)
    box.BackgroundColor3 = Color3.fromRGB(35, 35, 38)
    box.Text = default and "X" or ""
    box.Font = Enum.Font.GothamBold
    box.TextColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)
    
    local state = default
    box.MouseButton1Click:Connect(function()
        state = not state
        box.Text = state and "X" or ""
        callback(state)
    end)
end

createToggle("Habilitar Notificacoes", true, function(v) configData.notificationsEnabled = v end)
createToggle("Trava de Execucao", true, function(v) configData.duplicateLockEnabled = v end)
createToggle("Compartilhamento de Dados", false, function(v) configData.dataSharingEnabled = v end)

-- 4. LÓGICA DE ARRASTO DO BOTÃO (CORRIGIDA)
local draggingBtn = false
local dragStartBtn, startPosBtn, hasMoved
openButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingBtn = true
        dragStartBtn = input.Position
        startPosBtn = openButton.Position
        hasMoved = false
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingBtn = false
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if draggingBtn and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStartBtn
        if delta.Magnitude > 5 then
            hasMoved = true
            openButton.Position = UDim2.new(startPosBtn.X.Scale, startPosBtn.X.Offset + delta.X, startPosBtn.Y.Scale, startPosBtn.Y.Offset + delta.Y)
        end
    end
end)

-- Substituir o evento original do botão abrir para respeitar o arrasto
for _, connection in pairs(getconnections(openButton.MouseButton1Click)) do
    connection:Disable()
end
openButton.MouseButton1Click:Connect(function()
    if not hasMoved then
        main.Visible = not main.Visible
    end
end)

-- 5. LÓGICA DE COMPARTILHAMENTO DE DADOS
RunService.Heartbeat:Connect(function()
    if configData.dataSharingEnabled then
        -- Lógica para manter as mudanças no veículo (suspensão/velocidade)
        -- Como o script original já tem loops, aqui apenas reforçamos a persistência
        local character = player.Character
        if character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.SeatPart then
                local vehicle = humanoid.SeatPart:FindFirstAncestorOfClass("Model")
                if vehicle then
                    -- Reforça as constraints continuamente
                    for _, d in ipairs(vehicle:GetDescendants()) do
                        if d:IsA("SpringConstraint") or d:IsA("PrismaticConstraint") then
                            -- Apenas mantém o estado atual
                        end
                    end
                end
            end
        end
    end
end)

