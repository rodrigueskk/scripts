-- Lógica de Backfire (Partícula)
local function createFire(part)
    local fire = Instance.new("ParticleEmitter")
    fire.Name = "BackfireEffect"
    fire.Texture = "rbxassetid://242202417"
    fire.Color = ColorSequence.new(Color3.fromRGB(255, 120, 0), Color3.fromRGB(255, 50, 0))
    fire.Rate = 150
    fire.Speed = NumberRange.new(5, 12)
    fire.Lifetime = NumberRange.new(0.1, 0.4)
    fire.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 1.5), NumberSequenceKeypoint.new(1, 0)})
    fire.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1)})
    fire.Enabled = false
    fire.Parent = part
    return fire
end

local lastVehicle = nil
local exhaustParticles = {}

RunService.Heartbeat:Connect(function()
    local vehicle = getVehicle()
    if vehicle ~= lastVehicle then
        exhaustParticles = {}
        lastVehicle = vehicle
        if vehicle then
            local body = vehicle:FindFirstChild("Body") or vehicle:FindFirstChild("body")
            if body then
                for _, obj in ipairs(body:GetDescendants()) do
                    if obj.Name == "Exhaust" and obj:IsA("BasePart") then
                        table.insert(exhaustParticles, createFire(obj))
                    end
                end
            end
            applyLightColor(vehicle, lightColor)
        end
    end
    for _, p in pairs(exhaustParticles) do p.Enabled = isBackfiring end
end)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == backfireKey then isBackfiring = true
    elseif input.KeyCode == Enum.KeyCode.RightBracket then main.Visible = not main.Visible end
end)
UserInputService.InputEnded:Connect(function(input) if input.KeyCode == backfireKey then isBackfiring = false end end)
