-- Cor de section = primária levemente mais escura (fator 0.75)
local function sectionColor()
    local r = math.clamp(tema.primaria.R * 0.75, 0, 1)
    local g = math.clamp(tema.primaria.G * 0.75, 0, 1)
    local b = math.clamp(tema.primaria.B * 0.75, 0, 1)
    -- garante mínimo de escuridão visível
    if r < 0.04 and g < 0.04 and b < 0.04 then
        r, g, b = 0.07, 0.07, 0.08
    end
    return Color3.new(r, g, b)
end

