local function getVehicle()
    local character = player.Character
    if not character then return nil end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return nil end
    local seatPart = humanoid.SeatPart
    if not seatPart then return nil end
    return seatPart:FindFirstAncestorOfClass("Model")
end

local function getVehicleSeat(vehicle)
    if not vehicle then return nil end
    for _, obj in ipairs(vehicle:GetDescendants()) do
        if obj:IsA("VehicleSeat") then return obj end
    end
    return nil
end

-- ============================================================
-- SUSPENSÃO
-- ============================================================
local function aplicarAlturaConstraint(c, altura)
    altura = clamp(altura, alturaMin, alturaMax)
    if c:IsA("SpringConstraint") then
        pcall(function() c.FreeLength = altura end)
    elseif c:IsA("PrismaticConstraint") then
        pcall(function()
            local half = clamp(math.abs(altura), alturaMin, alturaMax)
            c.LimitsEnabled = true
            c.LowerLimit = -half
            c.UpperLimit = half
        end)
    end
end

local function applyLocalSuspension(altura)
    currentSuspension = altura
    if compartilharDados then savedConfig.suspension = altura end
    local vehicle = getVehicle()
    if not vehicle then return end
    local constraints = {}
    for _, d in ipairs(vehicle:GetDescendants()) do
        if d:IsA("SpringConstraint") or d:IsA("PrismaticConstraint") then
            table.insert(constraints, d)
        end
    end
    if #constraints == 0 then return end
    local porTag = {FL={},FR={},RL={},RR={}}
    local temTag = 0
    for _, c in ipairs(constraints) do
        local tag = tagDaRoda(string.upper(c.Name))
        if tag then temTag = temTag+1; table.insert(porTag[tag], c) end
    end
    if temTag > 0 then
        for _, tag in ipairs({"FL","FR","RL","RR"}) do
            for _, c in ipairs(porTag[tag]) do aplicarAlturaConstraint(c, altura) end
        end
    else
        for _, c in ipairs(constraints) do aplicarAlturaConstraint(c, altura) end
    end
end

local function applyLocalSpeed(value)
    velocityMult = value / 1000
    if compartilharDados then savedConfig.speed = value end
end

local function applyLocalBrake(value)
    velocityMult2 = value / 1000
    if compartilharDados then savedConfig.brake = value end
end

local function applyTireGrip(vehicle, gripValue)
    if compartilharDados then savedConfig.grip = gripValue end
    if not vehicle then return end
    for _, part in ipairs(vehicle:GetDescendants()) do
        if part:IsA("BasePart") then
            local name = string.upper(part.Name)
            if string.find(name,"WHEEL") or string.find(name,"RODA") or string.find(name,"TIRE") or string.find(name,"PNEU") or tagDaRoda(name) then
                local cp = part.CustomPhysicalProperties or PhysicalProperties.new(part.Material)
                pcall(function()
                    part.CustomPhysicalProperties = PhysicalProperties.new(cp.Density, gripValue, cp.Friction, cp.FrictionWeight, cp.ElasticityWeight)
                end)
            end
        end
    end
end

-- ============================================================
-- TAMANHO DAS RODAS
-- ============================================================
local wheelSizeFator = 1.0
local wheelPartsOrig = {}
local wheelModels    = {}

local function encontrarPartesRodas(vehicle)
    if not vehicle then return {} end
    local partes = {}
    local pasta = nil
    for _, n in ipairs({"Wheels","wheels","Wheel","wheel","WHEELS","WHEEL"}) do
        pasta = vehicle:FindFirstChild(n, true)
        if pasta then break end
    end
    if pasta then
        for _, desc in ipairs(pasta:GetDescendants()) do
            if desc:IsA("BasePart") or desc:IsA("MeshPart") then table.insert(partes, desc) end
        end
        if #partes == 0 then
            for _, child in ipairs(pasta:GetChildren()) do
                if child:IsA("BasePart") or child:IsA("MeshPart") then table.insert(partes, child) end
            end
        end
    end
    if #partes == 0 then
        for _, desc in ipairs(vehicle:GetDescendants()) do
            if (desc:IsA("BasePart") or desc:IsA("MeshPart")) and tagDaRoda(desc.Name:upper()) then
                table.insert(partes, desc)
            end
        end
    end
    return partes
end

local function capturarTamanhosOriginais(vehicle)
    local partes = encontrarPartesRodas(vehicle)
    wheelPartsOrig = {}
    for _, p in ipairs(partes) do wheelPartsOrig[p] = p.Size end
    wheelModels = partes
    return #partes > 0
end

local function aplicarEscalaRodas(fator)
    for part, origSize in pairs(wheelPartsOrig) do
        if part and part.Parent then
            pcall(function() part.Size = origSize * fator end)
        end
    end
end

