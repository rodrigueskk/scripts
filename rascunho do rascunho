-- Dragging e Toggle
openButton.MouseButton1Click:Connect(function() main.Visible = not main.Visible end)
local dragStart, startPos, dragging
topBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true; dragStart = input.Position; startPos = main.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

-- Loop de Velocidade/Frenagem
RunService.Stepped:Connect(function()
    local v = getVehicle()
    local s = getVehicleSeat(v)
    if not s then return end
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then s.AssemblyLinearVelocity *= Vector3.new(1 + velocityMult, 1, 1 + velocityMult) end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then s.AssemblyLinearVelocity *= Vector3.new(1 - velocityMult2, 1, 1 - velocityMult2) end
end)

-- Tecla de atalho para fechar
UserInputService.InputBegan:Connect(function(input, gp)
    if not gp and input.KeyCode == Enum.KeyCode.RightBracket then main.Visible = not main.Visible end
end)
