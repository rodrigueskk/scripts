        rowL.Padding = UDim.new(0,2); rowL.SortOrder = Enum.SortOrder.LayoutOrder
        local nomeLbl = Instance.new("TextLabel"); nomeLbl.Parent = row
        nomeLbl.BackgroundTransparency = 1; nomeLbl.Size = UDim2.new(1,0,0,16)
        nomeLbl.Font = Enum.Font.GothamBold; nomeLbl.TextSize = 12
        nomeLbl.TextColor3 = dados.isAmigo and Color3.fromRGB(80,210,80) or Color3.fromRGB(150,150,210)
        nomeLbl.Text = dados.displayName.." (@"..dados.nome..")"; nomeLbl.TextXAlignment = Enum.TextXAlignment.Left; nomeLbl.ZIndex = 6
        local msgLbl = Instance.new("TextLabel"); msgLbl.Parent = row
        msgLbl.BackgroundTransparency = 1; msgLbl.Size = UDim2.new(1,0,0,0)
        msgLbl.AutomaticSize = Enum.AutomaticSize.Y; msgLbl.Font = Enum.Font.Gotham; msgLbl.TextSize = 12
        msgLbl.TextColor3 = Color3.fromRGB(230,230,238); msgLbl.Text = dados.mensagem
        msgLbl.TextWrapped = true; msgLbl.TextXAlignment = Enum.TextXAlignment.Left; msgLbl.ZIndex = 6
