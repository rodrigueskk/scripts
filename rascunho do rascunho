local function ehMeuVeiculo(vehicle)
    local myChar = player.Character
    if not myChar then return false end
    local hum = myChar:FindFirstChildOfClass("Humanoid")
    return hum and hum.SeatPart and hum.SeatPart:IsDescendantOf(vehicle)
end

local function criarESP(vehicle)
    if espSelections[vehicle] then return end

    local cor = ehMeuVeiculo(vehicle) and ESP_COR_PROPRIO or ESP_COR

    local sb = Instance.new("SelectionBox")
    sb.Adornee         = vehicle
    sb.Color3          = cor
    sb.LineThickness   = 0.04
    sb.SurfaceTransparency = 1        -- só borda, sem preenchimento
    sb.SurfaceColor3   = cor
    sb.Parent          = espFolder

    espSelections[vehicle] = sb
end

local function escanearVeiculos()
    -- Varre apenas os filhos diretos do workspace (não GetDescendants — muito pesado)
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and not espSelections[obj] then
            if obj:FindFirstChildWhichIsA("VehicleSeat", true) then
                criarESP(obj)
            end
        end
    end
    -- Remove boxes de veículos que sumiram
    for vehicle, sb in pairs(espSelections) do
        if not vehicle.Parent then
            pcall(function() sb:Destroy() end)
            espSelections[vehicle] = nil
        end
    end
end

