local function getVehicle()
    local character = player.Character
    if not character then return nil end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return nil end
    local seatPart = humanoid.SeatPart
    if not seatPart then return nil end
    return seatPart:FindFirstAncestorOfClass("Model")
end

local function getVehicleSeat(vehicle)
    if not vehicle then return nil end
    for _, obj in ipairs(vehicle:GetDescendants()) do
        if obj:IsA("VehicleSeat") then
            return obj
        end
    end
    return nil
end

-- Lógica de Suspensão
local function aplicarAlturaConstraint(c, altura)
    altura = clamp(altura, alturaMin, alturaMax)
    if c:IsA("SpringConstraint") then
        pcall(function() c.FreeLength = altura end)
    elseif c:IsA("PrismaticConstraint") then
        pcall(function()
            local half = clamp(math.abs(altura), alturaMin, alturaMax)
            c.LimitsEnabled = true
            c.LowerLimit = -half
            c.UpperLimit = half
        end)
    end
end

local function applyLocalSuspension(altura)
    currentSuspension = altura
    local vehicle = getVehicle()
    if not vehicle then return end
    local constraints = {}
    for _, d in ipairs(vehicle:GetDescendants()) do
        if d:IsA("SpringConstraint") or d:IsA("PrismaticConstraint") then
            table.insert(constraints, d)
        end
    end
    local porTag = {FL = {}, FR = {}, RL = {}, RR = {}}
    local temTag = 0
    for _, c in ipairs(constraints) do
        local tag = tagDaRoda(string.upper(c.Name))
        if tag then
            temTag += 1
            table.insert(porTag[tag], c)
        end
    end
    if temTag > 0 then
        for _, tag in ipairs({"FL","FR","RL","RR"}) do
            for _, c in ipairs(porTag[tag]) do aplicarAlturaConstraint(c, altura) end
        end
    else
        for _, c in ipairs(constraints) do aplicarAlturaConstraint(c, altura) end
    end
end

-- Lógica de Efeitos Visuais (O que outros podem ver)
local function applyNeonEffect(state)
    local vehicle = getVehicle()
    if not vehicle then return end
    for _, part in ipairs(vehicle:GetDescendants()) do
        if part:IsA("BasePart") and (part.Name:lower():find("neon") or part.Name:lower():find("glow")) then
            part.Material = state and Enum.Material.Neon or Enum.Material.Plastic
        end
    end
end

local function applyUnderglow(color)
    local vehicle = getVehicle()
    if not vehicle then return end
    local body = vehicle:FindFirstChild("Body") or vehicle:FindFirstChild("Chassis") or vehicle
    local existing = body:FindFirstChild("ComitUnderglow")
    if existing then existing:Destroy() end
    
    if color then
        local attachment = Instance.new("Attachment")
        attachment.Name = "ComitUnderglow"
        attachment.Position = Vector3.new(0, -1.5, 0)
        attachment.Parent = getVehicleSeat(vehicle) or body:FindFirstChildWhichIsA("BasePart")
        
        local light = Instance.new("PointLight")
        light.Color = color
        light.Brightness = 3
        light.Range = 15
        light.Shadows = true
        light.Parent = attachment
    end
end

local function applyFireParticles(state)
    local vehicle = getVehicle()
    if not vehicle then return end
    local seat = getVehicleSeat(vehicle)
    if not seat then return end
    local existing = seat:FindFirstChild("ComitParticles")
    if existing then existing:Destroy() end
    
    if state then
        local attachment = Instance.new("Attachment")
        attachment.Name = "ComitParticles"
        attachment.Parent = seat
        
        local particles = Instance.new("ParticleEmitter")
        particles.Acceleration = Vector3.new(0, 5, 0)
        particles.Lifetime = NumberRange.new(0.5, 1)
        particles.Rate = 50
        particles.Speed = NumberRange.new(2, 5)
        particles.Size = NumberSequence.new(0.5, 0)
        particles.Transparency = NumberSequence.new(0, 1)
        particles.Texture = "rbxassetid://2430535539" -- Fogo/Fumaça
        particles.Parent = attachment
    end
end

