local function getVehicle()
    local character = player.Character
    if not character then return nil end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return nil end
    local seatPart = humanoid.SeatPart
    if not seatPart then return nil end
    return seatPart:FindFirstAncestorOfClass("Model")
end

local function getVehicleSeat(vehicle)
    if not vehicle then return nil end
    for _, obj in ipairs(vehicle:GetDescendants()) do
        if obj:IsA("VehicleSeat") then
            return obj
        end
    end
    return nil
end

-- Lógica de Suspensão do script-ibicatu
local function aplicarAlturaConstraint(c, altura)
    altura = clamp(altura, alturaMin, alturaMax)
    if c:IsA("SpringConstraint") then
        local ok = pcall(function()
            c.FreeLength = altura
        end)
        return ok
    end
    if c:IsA("PrismaticConstraint") then
        local ok = pcall(function()
            local half = clamp(math.abs(altura), alturaMin, alturaMax)
            c.LimitsEnabled = true
            c.LowerLimit = -half
            c.UpperLimit = half
        end)
        return ok
    end
    return false
end

local function applyLocalSuspension(altura)
    currentSuspension = altura
    if compartilharDados then savedConfig.suspension = altura end
    local vehicle = getVehicle()
    if not vehicle then return end

    local constraints = {}
    for _, d in ipairs(vehicle:GetDescendants()) do
        if d:IsA("SpringConstraint") or d:IsA("PrismaticConstraint") then
            table.insert(constraints, d)
        end
    end

    if #constraints == 0 then return end

    local porTag = {FL = {}, FR = {}, RL = {}, RR = {}}
    local temTag = 0

    for _, c in ipairs(constraints) do
        local tag = tagDaRoda(string.upper(c.Name))
        if tag then
            temTag = temTag + 1
            table.insert(porTag[tag], c)
        end
    end

    if temTag > 0 then
        for _, tag in ipairs({"FL","FR","RL","RR"}) do
            for _, c in ipairs(porTag[tag]) do
                aplicarAlturaConstraint(c, altura)
            end
        end
    else
        for _, c in ipairs(constraints) do
            aplicarAlturaConstraint(c, altura)
        end
    end
end

-- Lógica de Velocidade e Frenagem (Multiplicadores)
local function applyLocalSpeed(value)
    velocityMult = value / 1000
    if compartilharDados then savedConfig.speed = value end
end

local function applyLocalBrake(value)
    velocityMult2 = value / 1000
    if compartilharDados then savedConfig.brake = value end
end

-- Lógica de Aderência (Grip) Adicionada
local function applyTireGrip(vehicle, gripValue)
    if compartilharDados then savedConfig.grip = gripValue end
    if not vehicle then return end
    for _, part in ipairs(vehicle:GetDescendants()) do
        if part:IsA("BasePart") then
            local name = string.upper(part.Name)
            if string.find(name, "WHEEL") or string.find(name, "RODA") or string.find(name, "TIRE") or string.find(name, "PNEU") or tagDaRoda(name) then
                local currentProps = part.CustomPhysicalProperties or PhysicalProperties.new(part.Material)
                part.CustomPhysicalProperties = PhysicalProperties.new(currentProps.Density, gripValue, currentProps.Friction, currentProps.FrictionWeight, currentProps.ElasticityWeight)
            end
        end
    end
end

