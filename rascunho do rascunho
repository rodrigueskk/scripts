-- AUTOFARM
-- ============================================================
local autoFarmAtivo = false
local autoFarmDir   = 1
local autoFarmConn  = nil
local AUTO_ALTURA   = 300
local AUTO_SPEED    = 1500

local function pararAutoFarm()
    autoFarmAtivo = false
    if autoFarmConn then autoFarmConn:Disconnect(); autoFarmConn = nil end
end

local function iniciarAutoFarm()
    local vehicle = getVehicle()
    if not vehicle then notify("AutoFarm", "Entre em um carro primeiro!", 3); return end
    local seat0 = getVehicleSeat(vehicle)
    if seat0 then pcall(function() seat0.MaxSpeed = 9999 end) end
    autoFarmAtivo = true; autoFarmDir = 1
    autoFarmConn = RunService.Stepped:Connect(function()
        if not autoFarmAtivo then return end
        local v2 = getVehicle(); local seat = v2 and getVehicleSeat(v2)
        if not seat then pararAutoFarm(); return end
        pcall(function() seat.MaxSpeed = 9999 end)
        local pos = seat.Position
        if pos.Y < AUTO_ALTURA - 5 then
            seat.AssemblyLinearVelocity = Vector3.new(0, AUTO_SPEED, 0)
        else
            seat.AssemblyLinearVelocity = Vector3.new(AUTO_SPEED * autoFarmDir, 0, 0)
            seat.AssemblyAngularVelocity = Vector3.new(0,0,0)
            if math.abs(pos.X) > 400 then autoFarmDir = -autoFarmDir end
        end
    end)
end

