local function criarSliderCor(parent, titulo, getVal, setVal, zBase)
    local holder = Instance.new("Frame")
    holder.Parent = parent
    holder.Size = UDim2.new(1, 0, 0, 26)
    holder.BackgroundTransparency = 1
    holder.ZIndex = zBase

    local lbl = Instance.new("TextLabel"); lbl.Parent = holder
    lbl.BackgroundTransparency = 1; lbl.Size = UDim2.new(0, 24, 1, 0)
    lbl.Font = Enum.Font.GothamMedium; lbl.TextSize = 11
    lbl.TextColor3 = Color3.fromRGB(180,180,185); lbl.Text = titulo; lbl.ZIndex = zBase+1

    local valLbl = Instance.new("TextLabel"); valLbl.Parent = holder
    valLbl.BackgroundTransparency = 1; valLbl.Size = UDim2.new(0,28,1,0)
    valLbl.Position = UDim2.new(1,-28,0,0)
    valLbl.Font = Enum.Font.GothamBold; valLbl.TextSize = 11
    valLbl.TextColor3 = Color3.fromRGB(255,255,255); valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.ZIndex = zBase+1

    local sFrame = Instance.new("Frame"); sFrame.Parent = holder
    sFrame.Position = UDim2.new(0,28,0.5,-3); sFrame.Size = UDim2.new(1,-60,0,6)
    sFrame.BackgroundColor3 = Color3.fromRGB(45,45,50); sFrame.BorderSizePixel = 0; sFrame.ZIndex = zBase+1
    local sfc = Instance.new("UICorner"); sfc.CornerRadius = UDim.new(1,0); sfc.Parent = sFrame

    local fill = Instance.new("Frame"); fill.Parent = sFrame
    fill.BackgroundColor3 = tema.quaternaria; fill.BorderSizePixel = 0
    fill.ZIndex = zBase+2
    local fc = Instance.new("UICorner"); fc.CornerRadius = UDim.new(1,0); fc.Parent = fill
    table.insert(allSliderFills, fill)

    local knob = Instance.new("Frame"); knob.Parent = sFrame
    knob.AnchorPoint = Vector2.new(0.5,0.5); knob.Size = UDim2.new(0,14,0,14)
    knob.BackgroundColor3 = tema.quaternaria; knob.BorderSizePixel = 0; knob.ZIndex = zBase+3
    local kc = Instance.new("UICorner"); kc.CornerRadius = UDim.new(1,0); kc.Parent = knob
    table.insert(allSliderKnobs, knob)

    local cur = getVal()
    local function refresh()
        local pos = cur / 255
        fill.Size = UDim2.new(pos,0,1,0)
        knob.Position = UDim2.new(pos,0,0.5,0)
        valLbl.Text = tostring(math.floor(cur))
    end
    refresh()

    local drag = false
    sFrame.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true
            cur = math.clamp(math.floor(((inp.Position.X - sFrame.AbsolutePosition.X)/sFrame.AbsoluteSize.X)*255), 0, 255)
            setVal(cur); refresh()
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if drag and inp.UserInputType == Enum.UserInputType.MouseMovement then
            cur = math.clamp(math.floor(((inp.Position.X - sFrame.AbsolutePosition.X)/sFrame.AbsoluteSize.X)*255), 0, 255)
            setVal(cur); refresh()
        end
    end)
end

