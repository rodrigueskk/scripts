local function reaplicarConfigs()
    local vehicle = getVehicle(); if not vehicle then return end
    applyLocalSuspension(savedConfig.suspension)
    velocityMult  = savedConfig.speed  / 1000
    velocityMult2 = savedConfig.brake  / 1000
    applyTireGrip(vehicle, savedConfig.grip)
end

local function outroJogadorNoVeiculo(vehicle)
    if not vehicle then return false end
    for _, obj in ipairs(vehicle:GetDescendants()) do
        if (obj:IsA("Seat") or obj:IsA("VehicleSeat")) and obj.Occupant then
            local op = Players:GetPlayerFromCharacter(obj.Occupant.Parent)
            if op and op ~= player then return true end
        end
    end
    return false
end

local assentosMonitorados = {}
local function pararMonitorAssentos()
    for _, c in ipairs(assentosMonitorados) do pcall(function() c:Disconnect() end) end
    assentosMonitorados = {}
end

local function iniciarMonitorAssentos(vehicle)
    pararMonitorAssentos(); if not vehicle then return end
    for _, obj in ipairs(vehicle:GetDescendants()) do
        if obj:IsA("Seat") or obj:IsA("VehicleSeat") then
            local c = obj:GetPropertyChangedSignal("Occupant"):Connect(function()
                if not compartilharDados then return end
                local occ = obj.Occupant
                if occ then
                    local op = Players:GetPlayerFromCharacter(occ.Parent)
                    if op and op ~= player then task.wait(0.5); reaplicarConfigs() end
                end
            end)
            table.insert(assentosMonitorados, c)
        end
    end
end

local function monitorarAssento(char)
    local humanoid = char:WaitForChild("Humanoid", 10); if not humanoid then return end
    humanoid:GetPropertyChangedSignal("SeatPart"):Connect(function()
        if humanoid.SeatPart then
            task.wait(0.3); local vehicle = getVehicle()
            if vehicle then
                if compartilharDados then reaplicarConfigs() end
                iniciarMonitorAssentos(vehicle)
            end
        else
            pararMonitorAssentos()
        end
    end)
end

local character = player.Character or player.CharacterAdded:Wait()
monitorarAssento(character)
player.CharacterAdded:Connect(function(char) pararMonitorAssentos(); monitorarAssento(char) end)

