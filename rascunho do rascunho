-- 4. LÓGICA DE PERSISTÊNCIA (Compartilhamento de Dados)
RunService.Heartbeat:Connect(function()
    if configData.dataSharingEnabled then
        local vehicle = getVehicle()
        if vehicle then
            -- Força as mudanças mesmo que outros entrem
            for _, d in ipairs(vehicle:GetDescendants()) do
                if d:IsA("SpringConstraint") or d:IsA("PrismaticConstraint") then
                    -- Aplica a suspensão atual continuamente
                    local altura = clamp(currentSuspension, alturaMin, alturaMax)
                    if d:IsA("SpringConstraint") then d.FreeLength = altura end
                    if d:IsA("PrismaticConstraint") then
                        d.LimitsEnabled = true
                        d.LowerLimit = -altura
                        d.UpperLimit = altura
                    end
                end
            end
        end
    end
end)

