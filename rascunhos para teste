local function createSlider(parent, config)
	local holder = Instance.new("Frame")
	holder.Parent = parent
	holder.Size = UDim2.new(1, 0, 0, 62)
	holder.BackgroundTransparency = 1

	local label = Instance.new("TextLabel")
	label.Parent = holder
	label.BackgroundTransparency = 1
	label.Size = UDim2.new(1, -70, 0, 18)
	label.Font = Enum.Font.Gotham
	label.TextSize = 13
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextColor3 = Color3.fromRGB(220, 220, 220)
	label.Text = config.Title

	local valueLabel = Instance.new("TextLabel")
	valueLabel.Parent = holder
	valueLabel.BackgroundTransparency = 1
	valueLabel.Position = UDim2.new(1, -70, 0, 0)
	valueLabel.Size = UDim2.new(0, 70, 0, 18)
	valueLabel.Font = Enum.Font.GothamBold
	valueLabel.TextSize = 13
	valueLabel.TextXAlignment = Enum.TextXAlignment.Right
	valueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)

	local bar = Instance.new("Frame")
	bar.Parent = holder
	bar.Position = UDim2.new(0, 0, 0, 30)
	bar.Size = UDim2.new(1, 0, 0, 8)
	bar.BackgroundColor3 = Color3.fromRGB(40, 40, 44)
	bar.BorderSizePixel = 0

	local barCorner = Instance.new("UICorner")
	barCorner.CornerRadius = UDim.new(1, 0)
	barCorner.Parent = bar

	local fill = Instance.new("Frame")
	fill.Parent = bar
	fill.Size = UDim2.new(0, 0, 1, 0)
	fill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	fill.BorderSizePixel = 0

	local fillCorner = Instance.new("UICorner")
	fillCorner.CornerRadius = UDim.new(1, 0)
	fillCorner.Parent = fill

	local knob = Instance.new("Frame")
	knob.Parent = bar
	knob.Size = UDim2.new(0, 18, 0, 18)
	knob.AnchorPoint = Vector2.new(0.5, 0.5)
	knob.Position = UDim2.new(0, 0, 0.5, 0)
	knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	knob.BorderSizePixel = 0

	local knobCorner = Instance.new("UICorner")
	knobCorner.CornerRadius = UDim.new(1, 0)
	knobCorner.Parent = knob

	local currentValue = config.Default or config.Min
	local dragging = false

	local function render(value)
		local alpha = math.clamp((value - config.Min) / (config.Max - config.Min), 0, 1)
		fill.Size = UDim2.new(alpha, 0, 1, 0)
		knob.Position = UDim2.new(alpha, 0, 0.5, 0)
		valueLabel.Text = string.format(config.Format or "%.2f", value)
	end

	local function updateFromMouse(mouseX)
		local left = bar.AbsolutePosition.X
		local width = bar.AbsoluteSize.X
		local alpha = math.clamp((mouseX - left) / width, 0, 1)
		local value = config.Min + (config.Max - config.Min) * alpha

		if config.Step then
			value = math.round(value / config.Step) * config.Step
		end

		currentValue = math.clamp(value, config.Min, config.Max)
		render(currentValue)

		if config.Changed then
			config.Changed(currentValue)
		end
	end

	render(currentValue)

	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			updateFromMouse(input.Position.X)
		end
	end)

	knob.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			updateFromMouse(input.Position.X)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			updateFromMouse(input.Position.X)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	return {
		GetValue = function()
			return currentValue
		end,
		SetValue = function(v)
			currentValue = math.clamp(v, config.Min, config.Max)
			render(currentValue)
			if config.Changed then
				config.Changed(currentValue)
			end
		end
	}
end

local currentSuspension = 0
local currentSpeed = 80
local currentBrake = 80

local function applyLocalSuspension(amount)
	local vehicle = getVehicle()
	if not vehicle then
		return
	end

	local cache = buildVehicleCache(vehicle)
	amount = math.clamp(amount, -6, 10)
	currentSuspension = amount

	local basePivot = cache.basePivot
	local newPivot = basePivot * CFrame.new(0, amount, 0)
	vehicle:PivotTo(newPivot)

	for wheelName, parts in pairs(cache.wheels) do
		for _, part in ipairs(parts) do
			local original = cache.basePartCFrames[part]
			if original then
				local relative = basePivot:ToObjectSpace(original)
				local pos = relative.Position
				local _, yaw, _ = relative:ToEulerAnglesYXZ()
				local fixed = CFrame.new(pos) * CFrame.Angles(0, yaw, 0)
				part.CFrame = newPivot * fixed
			end
		end
	end
end

local speedLoop
local brakeLoop

local function applyLocalSpeed(value)
	currentSpeed = math.clamp(value, 20, 220)
	local vehicle = getVehicle()
	if not vehicle then
		return
	end

	local cache = buildVehicleCache(vehicle)
	local seat = cache.seat
	if seat then
		pcall(function()
			seat.MaxSpeed = currentSpeed
		end)
		pcall(function()
			seat.Torque = math.max(1000, currentSpeed * 30)
		end)
	end
end

local function applyLocalBrake(value)
	currentBrake = math.clamp(value, 20, 250)
	local vehicle = getVehicle()
	if not vehicle then
		return
	end

	for _, obj in ipairs(vehicle:GetDescendants()) do
		if obj:IsA("HingeConstraint") then
			pcall(function()
				if obj.ActuatorType == Enum.ActuatorType.Motor then
					obj.AngularResponsiveness = math.clamp(currentBrake / 8, 5, 50)
				end
			end)
		end
	end
end

