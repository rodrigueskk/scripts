    local delta = i.Position - dStart
    main.Position = UDim2.new(sPos.X.Scale, sPos.X.Offset + delta.X, sPos.Y.Scale, sPos.Y.Offset + delta.Y)
end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dDragging = false end end)

-- Loop Velocidade/Frenagem
RunService.Stepped:Connect(function()
    local v = getVehicle()
    local s = getVehicleSeat(v)
    if not s then return end
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then s.AssemblyLinearVelocity *= Vector3.new(1 + velocityMult, 1, 1 + velocityMult) end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then s.AssemblyLinearVelocity *= Vector3.new(1 - velocityMult2, 1, 1 - velocityMult2) end
end)

UserInputService.InputBegan:Connect(function(i, gp) if not gp and i.KeyCode == Enum.KeyCode.RightBracket then main.Visible = not main.Visible end end)
