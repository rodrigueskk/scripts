local alturaMin, alturaMax = 0.05, 8
local velocityMult, velocityMult2 = 0.025, 0.150
local currentSuspension = 2.5

local tokensRoda = {
    FL = {"FL","FRONTLEFT","FRONT_LEFT","LEFTFRONT","LEFT_FRONT"},
    FR = {"FR","FRONTRIGHT","FRONT_RIGHT","RIGHTFRONT","RIGHT_FRONT"},
    RL = {"RL","REARLEFT","REAR_LEFT","LEFTREAR","LEFT_REAR","BACKLEFT","BACK_LEFT"},
    RR = {"RR","REARRIGHT","REAR_RIGHT","RIGHTREAR","RIGHT_REAR","BACKRIGHT","BACK_RIGHT"},
}

local function tagDaRoda(nomeUpper)
    for tag, lista in pairs(tokensRoda) do
        for _, t in ipairs(lista) do
            if nomeUpper:find(t, 1, true) then return tag end
        end
    end
    return nil
end

local function getVehicle()
    local char = player.Character
    if not char then return nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or not hum.SeatPart then return nil end
    return hum.SeatPart:FindFirstAncestorOfClass("Model")
end

local function getVehicleSeat(vehicle)
    if not vehicle then return nil end
    for _, obj in ipairs(vehicle:GetDescendants()) do
        if obj:IsA("VehicleSeat") then return obj end
    end
    return nil
end

-- Lógica de Rodas (Camber e Espaçador)
local originalOffsets = {}

local function applyCamberAndSpacer(camberValue, spacerValue)
    local vehicle = getVehicle()
    if not vehicle then return end
    
    for _, d in ipairs(vehicle:GetDescendants()) do
        if d:IsA("Attachment") then
            local parentName = d.Parent and d.Parent.Name or ""
            local tag = tagDaRoda(string.upper(parentName)) or tagDaRoda(string.upper(d.Name))
            
            if tag then
                -- Espaçador (Offset)
                if not originalOffsets[d] then originalOffsets[d] = d.Position end
                local basePos = originalOffsets[d]
                
                if tag == "FL" or tag == "RL" then
                    d.Position = Vector3.new(basePos.X + spacerValue, basePos.Y, basePos.Z)
                    d.Orientation = Vector3.new(d.Orientation.X, d.Orientation.Y, camberValue)
                elseif tag == "FR" or tag == "RR" then
                    d.Position = Vector3.new(basePos.X - spacerValue, basePos.Y, basePos.Z)
                    d.Orientation = Vector3.new(d.Orientation.X, d.Orientation.Y, -camberValue)
                end
            end
        end
    end
end

