local function getVehicle()
	local character = player.Character
	if not character then
		return nil
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return nil
	end

	local seatPart = humanoid.SeatPart
	if not seatPart then
		return nil
	end

	return seatPart:FindFirstAncestorOfClass("Model")
end

local function getVehicleSeat(vehicle)
	if not vehicle then
		return nil
	end

	for _, obj in ipairs(vehicle:GetDescendants()) do
		if obj:IsA("VehicleSeat") then
			return obj
		end
	end

	return nil
end

local wheelAliases = {
	FL = {"FL", "FrontLeft", "WheelFL", "LF", "LeftFront"},
	FR = {"FR", "FrontRight", "WheelFR", "RF", "RightFront"},
	RL = {"RL", "RearLeft", "WheelRL", "LR", "LeftRear"},
	RR = {"RR", "RearRight", "WheelRR", "RR", "RightRear"}
}

local function nameMatches(partName, aliases)
	for _, alias in ipairs(aliases) do
		if string.lower(partName) == string.lower(alias) then
			return true
		end
	end
	return false
end

local cacheByVehicle = {}

local function buildVehicleCache(vehicle)
	if cacheByVehicle[vehicle] then
		return cacheByVehicle[vehicle]
	end

	local cache = {
		basePivot = vehicle:GetPivot(),
		basePartCFrames = {},
		wheels = {
			FL = {},
			FR = {},
			RL = {},
			RR = {}
		},
		seatDefaults = {}
	}

	for _, obj in ipairs(vehicle:GetDescendants()) do
		if obj:IsA("BasePart") then
			cache.basePartCFrames[obj] = obj.CFrame

			for wheelName, aliases in pairs(wheelAliases) do
				if nameMatches(obj.Name, aliases) then
					table.insert(cache.wheels[wheelName], obj)
				end
			end
		end
	end

	local seat = getVehicleSeat(vehicle)
	if seat then
		cache.seatDefaults.MaxSpeed = seat.MaxSpeed
		cache.seatDefaults.Torque = seat.Torque
		cache.seat = seat
	end

	cacheByVehicle[vehicle] = cache
	return cache
end

local function clearDeadCaches()
	for vehicle in pairs(cacheByVehicle) do
		if not vehicle or not vehicle.Parent then
			cacheByVehicle[vehicle] = nil
		end
	end
end

